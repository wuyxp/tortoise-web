# Tortoise 主页变量 (PL 换域名 / 邮箱 / 商店 URL 时只改这里 + GitHub Secrets 同名)
# 复制本文件为 .env 填实际值; 切勿入库 (.gitignore 已排除)

# ===== 站点基础 =====
PUBLIC_SITE_URL=https://serpilo.com
PUBLIC_SITE_NAME=Tortoise
PUBLIC_SITE_DESCRIPTION=陪伴孩子建立健康的屏幕使用习惯
PUBLIC_SITE_LOCALE=zh-CN

# ===== 外部链接 =====
PUBLIC_GITHUB_REPO=https://github.com/wuyxp/kotlin-stop-shortTV
PUBLIC_FEEDBACK_EMAIL=tortoise@example.com
# V1 灰度后填真实链接, V1 阶段保持 # (代码侧检测 # 隐藏 CTA)
PUBLIC_PLAY_STORE_URL=#
PUBLIC_DOMESTIC_STORE_URL=#

# ===== 阿里云部署 (写入 GitHub Secrets, 不入库本地 .env) =====
# 本地 dev / build 不需要; 仅 CI 用
# ALIYUN_HOST=<阿里云 ECS 公网 IP>
# ALIYUN_SSH_USER=root
# ALIYUN_SSH_KEY=<PEM 私钥内容>
# ALIYUN_DEPLOY_PATH=/var/www/serpilo

# ===== 跨仓 dispatch (Tortoise 主仓 → tortoise-web) =====
# 在 Tortoise 主仓 Secrets 配 TORTOISE_WEB_TOKEN (GitHub PAT, scopes: repo + workflow)
# 本仓不需要本地配置
