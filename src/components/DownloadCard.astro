---
// PL 通过 GitHub Secret PUBLIC_APK_DOWNLOAD_URL 控制开关:
//   '#' (默认) → 占位状态 "V1 即将发布"
//   真 URL    → 真下载状态 (按钮 + 二维码 encode 真 URL + 微信引导)
import { Smartphone, Shield, Wifi, MessageCircle, MoreHorizontal, ExternalLink, Ship, Lock, X, Download, Info } from 'lucide-astro';
import QRCode from 'qrcode-svg';
import type { ui } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  apkUrl: string;
  apkUrlCn: string;
  version: string;
  sha256Fp: string;
  sizeMb: string;
  feedbackEmail: string;
  lang: keyof typeof ui;
}

const { apkUrl, apkUrlCn, version, sha256Fp, sizeMb, feedbackEmail, lang } = Astro.props;
const t = useTranslations(lang);
const isAvailable = apkUrl !== '#';

// 公开二维码 (仅在已发布状态显示)
const qrSvg = new QRCode({
  content: apkUrl,
  padding: 2,
  width: 256,
  height: 256,
  color: '#B45309', // 金色
  background: 'transparent',
  ecl: 'M',
}).svg();

// 内部测试二维码 (指向最新地址; dl 独立下载域名 MEETING-2026-06-25 [via-sonnet-subagent] 机械 URL 替换)
const internalQrSvg = new QRCode({
  content: 'https://dl.serpilo.com/downloads/latest.apk',
  padding: 2,
  width: 256,
  height: 256,
  color: '#1a1a2e',
  background: 'transparent',
  ecl: 'M',
}).svg();

const sha256Short = sha256Fp.length >= 8 ? sha256Fp.slice(0, 8) : sha256Fp;
const sizeHint = t('download.size_hint').replace('{size}', sizeMb);
---

<div class="glass-darker p-8 md:p-16 rounded-[4rem] border-2 border-brand-blue/10 relative overflow-hidden">
  <!-- 背景装饰: 海浪 -->
  <div class="absolute bottom-0 left-0 w-full opacity-10 pointer-events-none">
    <svg viewBox="0 0 1440 320" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto translate-y-20">
      <path fill="currentColor" class="text-brand-blue" d="M0,160L48,176C96,192,192,224,288,224C384,224,480,192,576,165.3C672,139,768,117,864,128C960,139,1056,181,1152,197.3C1248,213,1344,203,1392,197.3L1440,192L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
    </svg>
  </div>

  {!isAvailable ? (
    <!-- 占位状态: V1 即将发布 -->
    <div class="text-center relative z-10">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-brand-blue/10 rounded-full text-brand-blue font-bold text-sm mb-6 animate-pulse">
        <Ship class="w-4 h-4" />
        {t('download.preparing')}
      </div>
      <p class="text-3xl md:text-5xl font-black text-brand-blue mb-4 leading-tight">{t('download.title2')}</p>
      <p class="text-lg text-gray-500 mb-12 max-w-md mx-auto">{t('download.preparing_desc')}</p>

      <div class="flex flex-col items-center gap-8">
        <div class="relative group">
          <!-- 装饰边框: 蓝色海洋风 (不显示二维码，显示锁定图标) -->
          <div class="absolute -inset-4 bg-brand-blue/5 rounded-[3rem] border border-brand-blue/10"></div>
          <div class="absolute -inset-2 bg-white/80 backdrop-blur rounded-[2.8rem] shadow-xl border border-white"></div>

          <div class="relative w-64 h-64 flex flex-col items-center justify-center gap-4 text-brand-blue/20">
            <Lock class="w-16 h-16 animate-pulse" stroke-width={1.5} />
            <p class="font-black text-sm uppercase tracking-widest">{t('download.preparing')}</p>
          </div>

          <!-- 装饰元素 -->
          <div class="absolute -top-6 -right-6 text-4xl animate-bounce">🐢</div>
        </div>

        <div class="flex flex-col items-center gap-4">
          <a href={`mailto:${feedbackEmail}`} class="group flex items-center gap-2 text-brand-green font-black text-xl hover:scale-105 transition-all">
            <span class="border-b-4 border-brand-green/20 group-hover:border-brand-green/60 transition-colors">
              {t('download.subscribe')}
            </span>
            <span class="group-hover:translate-x-2 transition-transform">→</span>
          </a>

          <!-- 内部测试入口 -->
          <button
            id="open-internal-test"
            class="text-xs text-gray-400 hover:text-brand-blue transition-colors cursor-pointer border-b border-transparent hover:border-brand-blue/30 mt-4"
          >
            {t('download.internal_test_entry')}
          </button>
        </div>
      </div>
    </div>
  ) : (
    <!-- 真状态: 下载按钮 + 副链 + 二维码 + 微信引导 + 系统要求 -->
    <div class="text-center relative z-10">
      <!-- 预发内测声明 (PL 2026-06-21 显式授权 [via-sonnet-subagent] §1.补.12 例外): 数据可能清理 / 可能有 bug -->
      <div class="max-w-xl mx-auto mb-10 flex items-start gap-3 text-left bg-amber-50 dark:bg-amber-900/10 border border-amber-200 dark:border-amber-800/30 rounded-3xl px-6 py-5">
        <Info class="w-5 h-5 text-amber-600 dark:text-amber-400 shrink-0 mt-0.5" />
        <div>
          <p class="font-black text-amber-700 dark:text-amber-400 text-sm mb-1">{t('download.prerelease_badge')}</p>
          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{t('download.prerelease_desc')}</p>
        </div>
      </div>

      <div class="flex flex-col items-center gap-6 mb-12">
        <a href={apkUrl}
           class="inline-block bg-brand-green text-white px-12 py-6 rounded-full font-black text-2xl shadow-[0_20px_50px_rgba(61,170,106,0.3)] hover:-translate-y-1 hover:shadow-[0_20px_60px_rgba(91,108,246,0.4)] transition-all duration-300">
          {t('download.cta')}
        </a>

        {apkUrlCn !== '#' && (
          <a href={apkUrlCn} class="text-brand-blue font-bold text-base hover:underline underline-offset-8 decoration-2 flex items-center gap-1">
            <ExternalLink class="w-4 h-4" />
            {t('download.cn_mirror')}
          </a>
        )}
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center max-w-4xl mx-auto">
        <!-- 二维码列 -->
        <div class="flex flex-col items-center gap-4">
          <div class="relative group">
            <!-- 二维码装饰边框: 金色沙滩风 -->
            <div class="absolute -inset-4 bg-amber-100 rounded-[3rem] rotate-2 group-hover:rotate-0 transition-transform duration-500 border border-amber-200"></div>
            <div class="absolute -inset-2 bg-white rounded-[2.8rem] shadow-xl"></div>

            <div class="relative w-64 h-64 flex items-center justify-center p-4" set:html={qrSvg} />

            <!-- 装饰元素: 海星/贝壳感 -->
            <div class="absolute -bottom-4 -left-4 text-3xl animate-float">⭐</div>
          </div>
          <p class="text-sm font-bold text-gray-500 mt-2">{t('download.qr_hint')}</p>
        </div>

        <!-- 微信引导 + 系统要求列 -->
        <div class="text-left space-y-8">
          <div class="bg-amber-50 dark:bg-amber-900/10 border border-amber-200 dark:border-amber-800/30 rounded-3xl p-6 shadow-sm">
            <div class="flex items-center gap-3 mb-4 text-amber-700 dark:text-amber-400">
              <MessageCircle class="w-6 h-6" />
              <p class="font-black text-lg">{t('download.weixin_title')}</p>
            </div>

            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-amber-200 dark:bg-amber-800 flex items-center justify-center text-xs font-bold shrink-0 mt-0.5">1</div>
                <p class="text-gray-700 dark:text-gray-300 flex items-center gap-2">
                  点击右上角 <MoreHorizontal class="w-4 h-4 inline" /> 菜单
                </p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-amber-200 dark:bg-amber-800 flex items-center justify-center text-xs font-bold shrink-0 mt-0.5">2</div>
                <p class="text-gray-700 dark:text-gray-300 flex items-center gap-2">
                  选择 <ExternalLink class="w-4 h-4 inline" /> {lang === 'zh' ? '在浏览器中打开' : 'Open in Browser'}
                </p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-brand-green/20 flex items-center justify-center text-xs font-bold shrink-0 mt-0.5 text-brand-green">3</div>
                <p class="text-brand-green font-bold">{lang === 'zh' ? '自动登岛下载' : 'Start landing!'}</p>
              </div>
            </div>
          </div>

          <div class="space-y-3 px-2">
            <div class="flex items-center gap-3 text-sm text-gray-500">
              <Smartphone class="w-5 h-5 text-brand-blue/60" />
              <span>{t('download.system_req')}</span>
            </div>
            <div class="flex items-center gap-3 text-sm text-gray-500">
              <Wifi class="w-5 h-5 text-brand-blue/60" />
              <span>{sizeHint}</span>
            </div>
            <div class="flex items-center gap-3 text-sm text-gray-500">
              <Shield class="w-5 h-5 text-brand-blue/60" />
              <!-- 版本/指纹未注入时 (latest.apk 滚动包) 显示滚动构建说明, 不露 sha256:pending [via-sonnet-subagent] -->
              {(version !== 'v0.0.0-pending' && sha256Fp !== 'pending') ? (
                <span class="font-mono">{version} · <span class="bg-gray-100 dark:bg-gray-800 px-1 rounded">sha256:{sha256Short}</span></span>
              ) : (
                <span>{t('download.rolling_build')}</span>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  )}
</div>

<!-- 内部测试弹窗 -->
<dialog id="internal-test-modal" class="m-auto bg-transparent backdrop:bg-black/60 p-4 border-0">
  <div class="glass-darker p-8 md:p-10 rounded-[3rem] border-2 border-brand-blue/20 max-w-md mx-auto flex flex-col items-center gap-8 relative animate-fade-in shadow-2xl">
    <button id="close-modal" class="absolute top-6 right-6 text-gray-400 hover:text-brand-blue transition-all hover:rotate-90">
      <X class="w-6 h-6" />
    </button>

    <div class="text-center">
      <h3 class="text-2xl font-black text-brand-blue mb-2">{t('download.internal_test_title')}</h3>
      <p class="text-sm text-gray-500 opacity-80">FOR DEVELOPERS & TESTERS ONLY</p>
    </div>

    <!-- 二维码展示区 -->
    <div class="relative group">
      <div class="absolute -inset-4 bg-brand-blue/5 rounded-[3rem] border border-brand-blue/10 animate-pulse"></div>
      <div class="absolute -inset-2 bg-white rounded-[2.8rem] shadow-xl"></div>
      <div class="relative w-64 h-64 flex items-center justify-center p-2" set:html={internalQrSvg} />
    </div>

    <!-- 功能按钮区 ([via-sonnet-subagent] dl 独立下载域名 MEETING-2026-06-25 机械 URL 替换) -->
    <div class="w-full space-y-3">
      <a href="https://dl.serpilo.com/downloads/latest.apk" target="_blank" class="flex items-center justify-between w-full glass px-6 py-4 rounded-2xl text-brand-blue font-bold hover:bg-brand-blue/10 transition-all hover:translate-x-1 group">
        <div class="flex items-center gap-3">
          <Download class="w-5 h-5" />
          <span>{t('download.internal_test_dl1')}</span>
        </div>
        <ExternalLink class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity" />
      </a>

      <!-- [via-sonnet-subagent] dl URL -->
      <a href="https://dl.serpilo.com/downloads/version.txt" target="_blank" class="flex items-center justify-between w-full bg-brand-blue/5 px-6 py-4 rounded-2xl text-brand-blue/70 text-sm font-bold hover:bg-brand-blue/10 transition-all group">
        <div class="flex items-center gap-3">
          <Info class="w-5 h-5" />
          <span>{t('download.internal_test_version')}</span>
        </div>
        <span class="text-xs opacity-40 group-hover:opacity-100 transition-opacity uppercase font-mono">version.txt</span>
      </a>
    </div>

    <p class="text-[10px] font-mono text-gray-400 opacity-50 uppercase tracking-tighter">
      Powered by Captain Mora Island Infra
    </p>
  </div>
</dialog>

<script>
  const openBtn = document.getElementById('open-internal-test');
  const closeBtn = document.getElementById('close-modal');
  const modal = document.getElementById('internal-test-modal') as HTMLDialogElement;

  if (openBtn && modal) {
    openBtn.addEventListener('click', () => {
      modal.showModal();
      document.body.style.overflow = 'hidden'; // 防止背景滚动
    });
  }

  if (closeBtn && modal) {
    const handleClose = () => {
      modal.close();
      document.body.style.overflow = '';
    };

    closeBtn.addEventListener('click', handleClose);

    // 点击背景关闭
    modal.addEventListener('click', (e) => {
      if (e.target === modal) handleClose();
    });

    // ESC 关闭
    modal.addEventListener('cancel', () => {
      document.body.style.overflow = '';
    });
  }
</script>

<style>
  dialog::backdrop {
    backdrop-filter: blur(12px);
    background-color: rgba(0, 0, 0, 0.4);
    animation: fade-in 0.3s ease-out;
  }

  dialog[open] {
    display: flex;
    animation: scale-up 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes scale-up {
    from { opacity: 0; transform: scale(0.9) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
