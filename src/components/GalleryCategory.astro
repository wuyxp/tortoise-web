---
import GalleryCard from './GalleryCard.astro';
import type { DrawableAsset } from '../data/drawables';

interface Props {
  title: string;
  assets: DrawableAsset[];
}

const { title, assets } = Astro.props;
---

<section class="mb-20">
  <div class="flex items-center gap-4 mb-10">
    <div class="h-[2px] w-12 bg-brand-blue/20"></div>
    <h2 class="text-2xl font-black tracking-widest text-brand-blue uppercase">{title}</h2>
    <div class="flex-1 h-[2px] bg-brand-blue/10"></div>
    <span class="text-xs font-bold text-gray-400">{assets.length} ITEMS</span>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
    {assets.map(asset => (
      <GalleryCard {...asset} />
    ))}
  </div>
</section>
