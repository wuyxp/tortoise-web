---
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import { getLangFromUrl, useTranslatedPath } from '../i18n/utils';

const { activeSlug } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);

// Load real docs to map sidebar paths to actual IDs
const allDocs = await getCollection('docs');
const docIdMap = new Map(allDocs.map(doc => [doc.id.toLowerCase(), doc.id]));

const sidebarPath = path.resolve('src/content/tortoise-source/_sidebar.md');
const sidebarContent = fs.readFileSync(sidebarPath, 'utf-8');

interface SidebarItem {
  title: string;
  slug?: string;
  children?: SidebarItem[];
}

function parseSidebar(content: string): SidebarItem[] {
  const lines = content.split('\n');
  const items: SidebarItem[] = [];
  let currentHeader: SidebarItem | null = null;

  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed || trimmed.startsWith('<!--')) continue;

    // Header Match: * Text
    const headerMatch = trimmed.match(/^\* ([^\[].+)$/);
    if (headerMatch) {
      currentHeader = { title: headerMatch[1], children: [] };
      items.push(currentHeader);
      continue;
    }

    // Link Match: * [Title](Path)
    const linkMatch = line.match(/^(\s*)\* \[([^\]]+)\]\(([^)]+)\)/);
    if (linkMatch) {
      const indent = linkMatch[1].length;
      const title = linkMatch[2];
      let rawPath = linkMatch[3];

      // Clean path: 01-overview/product-overview.md -> 01-overview/product-overview
      let id = rawPath.replace(/\.mdx?$/, '').replace(/^\.\//, '');

      // Attempt to find actual doc ID from map (case-insensitive lookup)
      const actualId = docIdMap.get(id.toLowerCase()) || id.toLowerCase();

      const item = { title, slug: actualId };

      if (indent > 0 && currentHeader) {
        currentHeader.children?.push(item);
      } else {
        items.push(item);
      }
    }
  }
  return items;
}

const sidebarItems = parseSidebar(sidebarContent);
---

<nav class="space-y-10 text-sm font-bold pb-20">
  {sidebarItems.map(item => (
    <div class="space-y-4">
      {item.slug ? (
        <a
          href={translatePath(`/docs/${item.slug}`)}
          class={`block py-2 px-4 rounded-xl transition-all ${activeSlug === item.slug ? 'glass-darker text-brand-blue translate-x-1' : 'hover:bg-black/5 dark:hover:bg-white/5 text-gray-900 dark:text-gray-100'}`}
        >
          {item.title}
        </a>
      ) : (
        <h5 class="px-4 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]">
          {item.title}
        </h5>
      )}

      {item.children && item.children.length > 0 && (
        <ul class="space-y-1 ml-4 border-l-2 border-black/5 dark:border-white/5">
          {item.children.map(child => (
            <li>
              <a
                href={translatePath(`/docs/${child.slug}`)}
                class={`block py-2.5 pl-6 -ml-[2px] border-l-2 transition-all group relative ${activeSlug === child.slug ? 'border-brand-blue text-brand-blue' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:border-gray-300'}`}
              >
                {activeSlug === child.slug && (
                  <div class="absolute left-[-2px] top-1/2 -translate-y-1/2 w-1.5 h-1.5 bg-brand-blue rounded-full blur-[2px]"></div>
                )}
                {child.title}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  ))}
</nav>
