---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter(h => h.depth > 1 && h.depth < 4);
---

{filteredHeadings.length > 0 && (
  <nav class="space-y-4">
    <h5 class="font-bold text-gray-900 dark:text-gray-100 text-xs uppercase tracking-wider">
      本页目录
    </h5>
    <ul class="space-y-3 text-sm">
      {filteredHeadings.map(h => (
        <li class={h.depth === 3 ? 'ml-4' : ''}>
          <a
            href={`#${h.slug}`}
            class="text-gray-500 dark:text-gray-400 hover:text-brand-blue transition-colors line-clamp-2 leading-snug"
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
