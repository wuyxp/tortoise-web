---
import '../styles/global.css';
import { Menu, X, Github, Mail, Sun, Moon } from 'lucide-astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = import.meta.env.PUBLIC_SITE_NAME ?? 'Tortoise',
  description = import.meta.env.PUBLIC_SITE_DESCRIPTION ?? '陪伴孩子建立健康的屏幕使用习惯',
} = Astro.props;

const siteName = import.meta.env.PUBLIC_SITE_NAME ?? 'Tortoise';
const githubRepo = import.meta.env.PUBLIC_GITHUB_REPO ?? 'https://github.com/wuyxp/kotlin-stop-shortTV';
const feedbackEmail = import.meta.env.PUBLIC_FEEDBACK_EMAIL ?? 'tortoise@example.com';
const fullTitle = title === siteName ? siteName : `${title} | ${siteName}`;
---

<!doctype html>
<html lang={import.meta.env.PUBLIC_SITE_LOCALE ?? 'zh-CN'} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_CN" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="min-h-screen bg-mint dark:bg-gray-950 text-gray-800 dark:text-gray-200 selection:bg-brand-blue selection:text-white">
    <!-- Header -->
    <header class="border-b border-black/5 dark:border-white/5 bg-white/70 dark:bg-gray-900/70 backdrop-blur-md sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 group transition-transform hover:scale-105">
          <img src="/images/illu_tortoise_wave.webp" alt="Logo" class="w-8 h-8 object-contain animate-float" />
          <span class="text-xl font-bold bg-gradient-to-r from-brand-green to-brand-blue bg-clip-text text-transparent">
            {siteName}
          </span>
        </a>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center gap-8 text-sm font-medium">
          <a href="/" class="hover:text-brand-blue transition-colors">首页</a>
          <a href="/docs/README" class="hover:text-brand-blue transition-colors">技术文档</a>
          <a href={githubRepo} target="_blank" rel="noopener" class="flex items-center gap-1 hover:text-brand-blue transition-colors">
            <Github size={16} /> GitHub
          </a>
          <button id="theme-toggle" class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" aria-label="切换主题">
            <Sun id="sun-icon" class="hidden dark:block" size={20} />
            <Moon id="moon-icon" class="block dark:hidden" size={20} />
          </button>
        </div>

        <!-- Mobile Menu Button -->
        <div class="md:hidden flex items-center gap-4">
           <button id="theme-toggle-mobile" class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800" aria-label="切换主题">
            <Moon size={20} class="block dark:hidden" />
            <Sun size={20} class="hidden dark:block" />
          </button>
          <button id="mobile-menu-btn" class="p-2 rounded-md hover:bg-gray-100 dark:hover:bg-gray-800" aria-label="菜单">
            <Menu id="menu-icon" size={24} />
            <X id="close-icon" size={24} class="hidden" />
          </button>
        </div>
      </nav>

      <!-- Mobile Nav Dropdown -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 px-6 py-6 space-y-4 shadow-xl">
        <a href="/" class="block text-lg font-medium hover:text-brand-blue">首页</a>
        <a href="/docs/README" class="block text-lg font-medium hover:text-brand-blue">技术文档</a>
        <a href={githubRepo} target="_blank" rel="noopener" class="flex items-center gap-2 text-lg font-medium hover:text-brand-blue">
          <Github size={20} /> GitHub
        </a>
      </div>
    </header>

    <main class="animate-fade-in">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-black/5 dark:border-white/5 mt-24 py-16 bg-white/40 dark:bg-gray-900/40">
      <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-4 gap-12">
        <div class="col-span-2">
          <div class="flex items-center gap-2 mb-4">
            <img src="/images/illu_tortoise_wave.webp" alt="Logo" class="w-6 h-6 object-contain" />
            <span class="text-lg font-bold text-brand-green">{siteName}</span>
          </div>
          <p class="text-sm text-gray-500 dark:text-gray-400 max-w-sm leading-relaxed">
            陪伴孩子建立健康的屏幕使用习惯。通过游戏化激励与温柔引导，让 6-14 岁儿童学会自主管理时间。
          </p>
        </div>
        <div>
          <h4 class="font-bold mb-4">资源</h4>
          <ul class="space-y-2 text-sm text-gray-500 dark:text-gray-400">
            <li><a href="/docs/README" class="hover:text-brand-blue transition-colors">技术文档</a></li>
            <li><a href={githubRepo} class="hover:text-brand-blue transition-colors">GitHub 源码</a></li>
            <li><a href="/docs/04-narrative/E19-arch-data-legal" class="hover:text-brand-blue transition-colors">隐私政策</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4">联系我们</h4>
          <ul class="space-y-2 text-sm text-gray-500 dark:text-gray-400">
            <li><a href={`mailto:${feedbackEmail}`} class="flex items-center gap-2 hover:text-brand-blue transition-colors"><Mail size={14}/> {feedbackEmail}</a></li>
          </ul>
        </div>
      </div>
      <div class="max-w-6xl mx-auto px-6 mt-16 pt-8 border-t border-black/5 dark:border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-400">
        <p>© 2026 {siteName} · 离线优先 · 无追踪</p>
        <p>Managed with ❤️ for the next generation</p>
      </div>
    </footer>

    <script>
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');

      mobileMenuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
        menuIcon?.classList.toggle('hidden');
        closeIcon?.classList.toggle('hidden');
      });

      const setupTheme = (id: string) => {
        const btn = document.getElementById(id);
        btn?.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      };

      setupTheme('theme-toggle');
      setupTheme('theme-toggle-mobile');
    </script>
  </body>
</html>
