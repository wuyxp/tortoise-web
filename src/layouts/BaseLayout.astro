---
// 基础布局骨架 (MEETING-2026-05-11-04-static-website-v1)
// Gemini 后续接力精修视觉 (海岛 brand / 字体 / 动画)
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = import.meta.env.PUBLIC_SITE_NAME ?? 'Tortoise',
  description = import.meta.env.PUBLIC_SITE_DESCRIPTION ?? '陪伴孩子建立健康的屏幕使用习惯',
} = Astro.props;

const siteName = import.meta.env.PUBLIC_SITE_NAME ?? 'Tortoise';
const githubRepo = import.meta.env.PUBLIC_GITHUB_REPO ?? 'https://github.com/wuyxp/kotlin-stop-shortTV';
const feedbackEmail = import.meta.env.PUBLIC_FEEDBACK_EMAIL ?? 'tortoise@example.com';
const fullTitle = title === siteName ? siteName : `${title} | ${siteName}`;
---

<!doctype html>
<html lang={import.meta.env.PUBLIC_SITE_LOCALE ?? 'zh-CN'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_CN" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-mint text-gray-800">
    <!-- 顶栏 -->
    <header class="border-b border-gray-200 bg-white/70 backdrop-blur sticky top-0 z-10">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-brand-green hover:opacity-80">
          🐢 {siteName}
        </a>
        <div class="flex items-center gap-6 text-sm">
          <a href="/" class="hover:text-brand-blue">首页</a>
          <a href="/docs/readme" class="hover:text-brand-blue">技术文档</a>
          <a href={githubRepo} target="_blank" rel="noopener" class="hover:text-brand-blue">
            GitHub
          </a>
        </div>
      </nav>
    </header>

    <!-- 内容 -->
    <main class="max-w-5xl mx-auto px-6 py-12">
      <slot />
    </main>

    <!-- 页脚 -->
    <footer class="border-t border-gray-200 mt-20 py-8 bg-white/40">
      <div class="max-w-5xl mx-auto px-6 text-center text-sm text-gray-500">
        <p>
          © 2026 {siteName} · 离线优先, 无追踪 ·
          <a href={`mailto:${feedbackEmail}`} class="text-brand-blue hover:underline">
            反馈邮箱
          </a>
        </p>
        <p class="mt-2 text-xs">
          骨架版本 (MEETING-2026-05-11-04 Phase A · Gemini 后续精修视觉)
        </p>
      </div>
    </footer>
  </body>
</html>
