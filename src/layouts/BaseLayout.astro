---
import '../styles/global.css';
import { Menu, X, Mail, Sun, Moon, Languages } from 'lucide-astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const {
  title = import.meta.env.PUBLIC_SITE_NAME ?? 'Tortoise',
  description = t('footer.description'),
} = Astro.props;

const siteName = import.meta.env.PUBLIC_SITE_NAME ?? 'Tortoise';
const feedbackEmail = import.meta.env.PUBLIC_FEEDBACK_EMAIL ?? '956826374@qq.com';
const fullTitle = title === siteName ? siteName : `${title} | ${siteName}`;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="min-h-screen mesh-gradient noise selection:bg-brand-blue selection:text-white">
    <!-- Header -->
    <header class="glass sticky top-0 z-50 border-b border-white/10">
      <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href={translatePath('/')} class="flex items-center gap-4 group transition-transform hover:scale-105 active:scale-95">
          <div class="relative w-12 h-12 flex items-center justify-center glass organic-radius overflow-hidden shadow-inner border border-white/20 rotate-[-3deg] group-hover:rotate-0 transition-transform duration-500">
            <div class="absolute inset-0 bg-brand-green/10 blur-md rounded-full group-hover:bg-brand-green/20 transition-colors"></div>
            <img src="/images/illu_tortoise_peek.webp" alt="Logo" class="w-10 h-10 object-contain relative z-10 group-hover:scale-110 transition-transform duration-500" />
          </div>
          <div class="flex flex-col">
            <span class="text-xl font-black text-gradient tracking-tight leading-none">
              {siteName}
            </span>
            <span class="text-[8px] font-black tracking-[0.3em] text-gray-400 mt-1 uppercase">Crystal Island</span>
          </div>
        </a>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center gap-10">
          <div class="flex items-center gap-8 text-sm font-bold text-gray-600 dark:text-gray-300">
            <a href={translatePath('/')} class="hover:text-brand-blue transition-all hover:translate-y-[-1px]">{t('nav.home')}</a>
            <a href={translatePath('/docs/01-overview/product-overview')} class="hover:text-brand-blue transition-all hover:translate-y-[-1px]">{t('nav.docs')}</a>
            <a href={translatePath('/gallery')} class="hover:text-brand-blue transition-all hover:translate-y-[-1px]">{t('nav.gallery')}</a>
          </div>
          <div class="h-4 w-px bg-black/10 dark:bg-white/10"></div>
          <div class="flex items-center gap-2">
            <button id="lang-toggle" class="p-2.5 rounded-2xl glass hover:bg-white/60 dark:hover:bg-gray-800/60 transition-all active:scale-90 flex items-center gap-2 text-xs font-black text-brand-blue" aria-label="Toggle Language">
               <Languages size={18} />
               <span class="uppercase">{lang}</span>
            </button>
            <button id="theme-toggle" class="p-2.5 rounded-2xl glass hover:bg-white/60 dark:hover:bg-gray-800/60 transition-all active:scale-90" aria-label="切换主题">
              <Sun id="sun-icon" class="hidden dark:block text-yellow-400" size={20} />
              <Moon id="moon-icon" class="block dark:hidden text-brand-blue" size={20} />
            </button>
          </div>
        </div>

        <!-- Mobile Menu Button -->
        <div class="md:hidden flex items-center gap-4">
           <button id="lang-toggle-mobile" class="p-2.5 rounded-xl glass flex items-center gap-2 text-xs font-black text-brand-blue" aria-label="Toggle Language">
            <Languages size={18} />
            <span class="uppercase">{lang}</span>
          </button>
           <button id="theme-toggle-mobile" class="p-2.5 rounded-xl glass" aria-label="切换主题">
            <Moon size={20} class="block dark:hidden" />
            <Sun size={20} class="hidden dark:block text-yellow-400" />
          </button>
          <button id="mobile-menu-btn" class="p-2.5 rounded-xl glass active:scale-90" aria-label="菜单">
            <Menu id="menu-icon" size={24} />
            <X id="close-icon" size={24} class="hidden" />
          </button>
        </div>
      </nav>

      <!-- Mobile Nav Dropdown -->
      <div id="mobile-menu" class="hidden md:hidden glass border-t border-black/5 dark:border-white/5 px-6 py-8 space-y-6 shadow-2xl animate-fade-in">
        <a href={translatePath('/')} class="block text-2xl font-bold hover:text-brand-blue transition-colors">{t('nav.home')}</a>
        <a href={translatePath('/docs/01-overview/product-overview')} class="block text-2xl font-bold hover:text-brand-blue transition-colors">{t('nav.docs')}</a>
        <a href={translatePath('/gallery')} class="block text-2xl font-bold hover:text-brand-blue transition-colors">{t('nav.gallery')}</a>
      </div>
    </header>

    <main class="animate-fade-in min-h-[calc(100vh-16rem)]">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-32 pb-24 relative overflow-hidden">
      <!-- Decoration Wave -->
      <div class="absolute top-0 left-0 w-full overflow-hidden leading-[0] h-20 opacity-30">
        <svg class="relative block w-[200%] h-full animate-wave" viewBox="0 0 1200 120" preserveAspectRatio="none">
          <path d="M0,0V46.29c47.79,22.2,103.59,32.17,158,28,70.36-5.37,136.33-33.31,206.8-37.5,73.84-4.36,147.54,16.88,218.2,35.26,69.27,18,138.3,24.88,209.4,13.08,36.15-6,69.85-17.84,104.45-29.34C989.49,25,1113,2,1200,34.29V0Z" class="fill-brand-blue"></path>
        </svg>
      </div>

      <div class="max-w-7xl mx-auto px-6 pt-24 grid md:grid-cols-4 gap-16 relative z-10">
        <div class="col-span-2">
          <div class="flex items-center gap-3 mb-8">
            <img src="/images/illu_tortoise_wave.webp" alt="Logo" class="w-8 h-8 object-contain" />
            <span class="text-2xl font-black text-brand-green tracking-tight">{siteName}</span>
          </div>
          <p class="text-lg text-gray-500 dark:text-gray-400 max-w-md leading-relaxed">
            {t('footer.description')}
          </p>
          <div class="flex gap-4 mt-8">
             <a href={`mailto:${feedbackEmail}`} class="p-3 rounded-2xl glass hover:text-brand-blue transition-all"><Mail size={24}/></a>
          </div>
        </div>

        <div class="space-y-6">
          <h4 class="text-xs font-black uppercase tracking-[0.2em] text-gray-400">{t('footer.resources')}</h4>
          <ul class="space-y-4 font-bold text-gray-600 dark:text-gray-300">
            <li><a href={translatePath('/docs/public/01-gentle-guidance-philosophy')} class="hover:text-brand-blue transition-colors">{t('nav.docs')}</a></li>
            <li><a href={translatePath('/docs/public/05-faq')} class="hover:text-brand-blue transition-colors">{t('footer.privacy')}</a></li>
          </ul>
        </div>

        <div class="space-y-6">
          <h4 class="text-xs font-black uppercase tracking-[0.2em] text-gray-400">{t('footer.support')}</h4>
          <ul class="space-y-4 font-bold text-gray-600 dark:text-gray-300">
            <li><a href={`mailto:${feedbackEmail}`} class="hover:text-brand-blue transition-colors flex items-center gap-2">{t('footer.feedback')}</a></li>
            <li class="text-sm text-gray-400 font-normal leading-relaxed">{t('footer.note')}</li>
          </ul>
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-6 mt-24 pt-12 border-t border-black/5 dark:border-white/5 flex flex-col md:row justify-between items-center gap-6">
        <div class="flex items-center gap-4 text-xs font-bold text-gray-400">
           <span>{t('footer.copyright')}</span>
           <span class="w-1 h-1 bg-gray-300 rounded-full"></span>
           <span>CRYSTAL ISLAND EDITION</span>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 glass rounded-full text-[10px] font-black text-brand-blue">
           <div class="w-2 h-2 bg-brand-green rounded-full animate-pulse"></div>
           {t('footer.status')}
        </div>
      </div>
    </footer>

    <script>
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');

      mobileMenuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
        menuIcon?.classList.toggle('hidden');
        closeIcon?.classList.toggle('hidden');
      });

      const setupTheme = (id: string) => {
        const btn = document.getElementById(id);
        btn?.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      };

      setupTheme('theme-toggle');
      setupTheme('theme-toggle-mobile');

      const setupLangToggle = (id: string) => {
        const btn = document.getElementById(id);
        btn?.addEventListener('click', () => {
          const currentPath = window.location.pathname;
          const currentLang = document.documentElement.lang;
          const newLang = currentLang === 'zh' ? 'en' : 'zh';

          let newPath = currentPath;
          if (currentLang === 'zh') {
            newPath = `/en${currentPath}`;
          } else {
            newPath = currentPath.replace(/^\/en/, '') || '/';
          }
          window.location.href = newPath;
        });
      };

      setupLangToggle('lang-toggle');
      setupLangToggle('lang-toggle-mobile');
    </script>
  </body>
</html>
