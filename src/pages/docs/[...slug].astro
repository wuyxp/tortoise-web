---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { ChevronRight, ExternalLink, Github, Copy, Check } from 'lucide-astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs', ({ data }) => data.public !== false);
  return docs.map(doc => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content, headings } = await render(doc);

const title = doc.data.title ?? doc.id.split('/').pop() ?? doc.id;
const description = doc.data.description ?? `${title} — Tortoise 技术文档`;
const githubUrl = `${import.meta.env.PUBLIC_GITHUB_REPO ?? 'https://github.com/wuyxp/kotlin-stop-shortTV'}/blob/main/docs/${doc.id}.md`;
---

<BaseLayout title={title} description={description}>
  <div class="max-w-7xl mx-auto px-6 py-10 flex gap-12">
    <!-- Left Sidebar (Sticky) -->
    <aside class="hidden lg:block w-64 shrink-0 sticky top-24 h-[calc(100vh-8rem)] overflow-y-auto pr-4 scrollbar-hide">
      <Sidebar activeSlug={doc.id} />
    </aside>

    <!-- Main Content -->
    <article class="flex-1 min-w-0">
      <!-- Breadcrumbs -->
      <nav class="flex items-center gap-2 text-xs text-gray-400 mb-8 overflow-x-auto whitespace-nowrap pb-2">
        <a href="/" class="hover:text-brand-blue">首页</a>
        <ChevronRight size={12} />
        <a href="/docs/readme" class="hover:text-brand-blue">文档</a>
        <ChevronRight size={12} />
        <span class="text-gray-600 dark:text-gray-300 font-medium truncate">{doc.id}</span>
      </nav>

      <div class="prose-tortoise">
        <Content />
      </div>

      <!-- Footer Metadata -->
      <footer class="mt-16 pt-8 border-t border-gray-100 dark:border-gray-800">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 text-sm text-gray-400">
           <p>源文件: <code class="text-xs bg-gray-50 dark:bg-gray-800 px-1 rounded">docs/{doc.id}.md</code></p>
           <a href={githubUrl} target="_blank" rel="noopener" class="flex items-center gap-1.5 text-brand-blue hover:underline font-medium">
             <Github size={14} /> 在 GitHub 编辑 <ExternalLink size={14} />
           </a>
        </div>
      </footer>
    </article>

    <!-- Right TOC (Sticky) -->
    <aside class="hidden xl:block w-56 shrink-0 sticky top-24 h-fit max-h-[calc(100vh-8rem)] overflow-y-auto">
      <TableOfContents headings={headings} />
    </aside>
  </div>

  <!-- Mermaid & Copy Button Script -->
  <script>
    import mermaid from 'mermaid';

    // Initialize Mermaid
    const isDark = document.documentElement.classList.contains('dark');
    mermaid.initialize({
      startOnLoad: true,
      theme: isDark ? 'dark' : 'default',
      securityLevel: 'loose',
      fontFamily: 'LXGW WenKai',
    });

    // Code block copy buttons
    const codeBlocks = document.querySelectorAll('pre');
    codeBlocks.forEach((block) => {
      const button = document.createElement('button');
      button.className = 'absolute top-3 right-3 p-2 bg-white/50 dark:bg-gray-800/50 backdrop-blur rounded-lg opacity-0 group-hover:opacity-100 transition-opacity hover:bg-white dark:hover:bg-gray-700 border border-black/5 dark:border-white/5';
      button.innerHTML = '<svg class="w-4 h-4 text-gray-600 dark:text-gray-300" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';

      block.classList.add('group', 'relative');
      block.appendChild(button);

      button.addEventListener('click', async () => {
        const code = block.querySelector('code')?.innerText || '';
        await navigator.clipboard.writeText(code);

        button.innerHTML = '<svg class="w-4 h-4 text-green-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
        setTimeout(() => {
          button.innerHTML = '<svg class="w-4 h-4 text-gray-600 dark:text-gray-300" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';
        }, 2000);
      });
    });

    // Re-render mermaid if theme changes
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
          const isDark = document.documentElement.classList.contains('dark');
          // For mermaid, we might need a full reload or manual re-init depending on implementation
          // Simplified: mermaid handles initial load.
        }
      });
    });
    observer.observe(document.documentElement, { attributes: true });
  </script>

  <style is:global>
    /* Hide scrollbar for Chrome, Safari and Opera */
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }
    /* Hide scrollbar for IE, Edge and Firefox */
    .scrollbar-hide {
      -ms-overflow-style: none;  /* IE and Edge */
      scrollbar-width: none;  /* Firefox */
    }

    /* Mermaid responsive */
    .mermaid {
      background: transparent !important;
      display: flex;
      justify-content: center;
      margin: 2rem 0;
    }
  </style>
</BaseLayout>
