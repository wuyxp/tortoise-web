---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { ChevronRight, BookOpen, PanelLeftClose, PanelRightClose, PanelLeft, PanelRight } from 'lucide-astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';

export async function getStaticPaths() {
  const docs = await getCollection('docs', ({ data, id }) => {
    if (data.public === false) return false;
    if (data.public === 'internal') return false;
    // ZH route: exclude EN translations (they live under public/en/)
    if (id.startsWith('public/en/')) return false;
    return true;
  });
  return docs.map(doc => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content, headings } = await render(doc);

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const title = doc.data.title ?? doc.id.split('/').pop() ?? doc.id;
const description = doc.data.description ?? `${title} — Tortoise 技术文档`;

// Determine badge based on file path or category
const getBadge = (id: string) => {
  if (id.startsWith('architecture/')) return { text: 'OFFICIAL ARCHITECTURE', color: 'text-brand-blue' };
  if (id.startsWith('04-narrative/')) return { text: 'NARRATIVE BIBLE', color: 'text-brand-green' };
  if (id.startsWith('03-explorer/')) return { text: 'EXPLORER SPEC', color: 'text-brand-blue' };
  if (id.includes('AUDIT')) return { text: 'PROJECT AUDIT', color: 'text-yellow-500' };
  return { text: 'TECHNICAL DOCUMENT', color: 'text-brand-blue' };
};

const badge = getBadge(doc.id);
---

<BaseLayout title={title} description={description}>
  <!-- Background Light Glow -->
  <div class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none opacity-40">
     <div class="absolute top-1/4 right-0 w-[500px] h-[500px] bg-brand-blue/10 blur-[150px] rounded-full"></div>
  </div>

  <div class="max-w-[1600px] mx-auto px-6 py-12 md:py-20 flex flex-col lg:flex-row gap-8 relative">

    <!-- Collapsible Sidebar Wrapper -->
    <aside id="sidebar-container" class="hidden lg:block w-80 shrink-0 sticky top-32 h-[calc(100vh-12rem)] transition-all duration-500 ease-in-out">
      <div id="sidebar-content" class="h-full overflow-y-auto pr-6 custom-scrollbar scroll-smooth">
        <div class="flex justify-between items-center mb-10 px-4">
           <span class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400">{t('docs.navigation')}</span>
           <button id="close-sidebar" class="p-2 glass rounded-xl hover:bg-white/60 dark:hover:bg-gray-800/60 transition-colors" title="Collapse Sidebar">
             <PanelLeftClose size={18} class="text-brand-blue" />
           </button>
        </div>
        <Sidebar activeSlug={doc.id} />
      </div>
    </aside>

    <!-- Sidebar Toggle (When closed) -->
    <button id="open-sidebar" class="hidden fixed left-6 top-1/2 -translate-y-1/2 p-3 glass rounded-2xl z-40 hover:scale-110 active:scale-90 transition-all opacity-0 pointer-events-none shadow-2xl" title="Open Sidebar">
       <PanelLeft size={24} class="text-brand-blue" />
    </button>

    <!-- Main Content -->
    <article id="main-content" class="flex-1 min-w-0 transition-all duration-500 ease-in-out">
      <!-- Premium Breadcrumbs -->
      <nav class="flex items-center gap-3 text-[11px] font-black uppercase tracking-[0.15em] text-gray-400 mb-12">
        <a href={translatePath('/')} class="hover:text-brand-blue transition-colors">{t('docs.breadcrumb.home')}</a>
        <ChevronRight size={14} class="text-gray-300" />
        <a href={translatePath('/docs/public/01-gentle-guidance-philosophy')} class="hover:text-brand-blue transition-colors">{t('docs.breadcrumb.docs')}</a>
        <ChevronRight size={14} class="text-gray-300" />
        <span class="text-brand-green truncate">{doc.id}</span>
      </nav>

      <!-- Glass Content Wrap -->
      <div class="glass p-8 md:p-16 rounded-[3rem] shadow-2xl relative w-full">
        <!-- Floating Badge -->
        <div class="absolute -top-6 left-12 glass-darker px-6 py-3 rounded-2xl flex items-center gap-3 text-sm font-black shadow-lg border-2 border-brand-blue/10">
           <BookOpen size={18} class={badge.color} />
           <span class={badge.color}>{badge.text}</span>
        </div>

        <div class="prose-tortoise w-full">
          <Content />
        </div>
      </div>

      <!-- Enhanced Footer Metadata -->
      <footer class="mt-20 pt-12 border-t border-black/5 dark:border-white/5 space-y-8">
        <div class="flex flex-col sm:flex-row justify-between items-center gap-6">
           <div class="flex items-center gap-3 px-4 py-2 glass rounded-2xl text-xs font-bold text-gray-400">
             <span>{t('docs.source')}</span>
             <code class="bg-black/5 dark:bg-white/5 px-2 py-1 rounded text-[10px]">{doc.id}.md</code>
           </div>
        </div>
      </footer>
    </article>

    <!-- Collapsible TOC Wrapper -->
    <aside id="toc-container" class="hidden xl:block w-72 shrink-0 sticky top-32 h-fit max-h-[calc(100vh-12rem)] transition-all duration-500 ease-in-out">
      <div class="glass p-8 rounded-[2.5rem] border-2 border-black/5 dark:border-white/5 relative">
        <div class="flex justify-between items-center mb-6">
           <span class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400">{t('docs.on_this_page')}</span>
           <button id="close-toc" class="p-1.5 glass rounded-lg hover:bg-white/40 transition-colors" title="Collapse TOC">
             <PanelRightClose size={14} class="text-brand-blue" />
           </button>
        </div>
        <TableOfContents headings={headings} />
      </div>
    </aside>

     <!-- TOC Toggle (When closed) -->
     <button id="open-toc" class="hidden fixed right-6 top-1/2 -translate-y-1/2 p-3 glass rounded-2xl z-40 hover:scale-110 active:scale-90 transition-all opacity-0 pointer-events-none shadow-2xl" title="Open TOC">
       <PanelRight size={24} class="text-brand-blue" />
    </button>
  </div>

  <script>
    import mermaid from 'mermaid';

    // Sidebar & TOC Collapsible Logic
    const sidebarContainer = document.getElementById('sidebar-container');
    const closeSidebarBtn = document.getElementById('close-sidebar');
    const openSidebarBtn = document.getElementById('open-sidebar');

    const tocContainer = document.getElementById('toc-container');
    const closeTocBtn = document.getElementById('close-toc');
    const openTocBtn = document.getElementById('open-toc');

    const togglePanel = (container, openBtn, state) => {
      if (state === 'close') {
        container.style.width = '0';
        container.style.opacity = '0';
        container.style.pointerEvents = 'none';
        container.style.marginRight = '0';
        container.style.marginLeft = '0';
        openBtn.style.opacity = '1';
        openBtn.style.pointerEvents = 'auto';
      } else {
        container.style.width = container.id === 'sidebar-container' ? '20rem' : '18rem';
        container.style.opacity = '1';
        container.style.pointerEvents = 'auto';
        openBtn.style.opacity = '0';
        openBtn.style.pointerEvents = 'none';
      }
    };

    closeSidebarBtn?.addEventListener('click', () => togglePanel(sidebarContainer, openSidebarBtn, 'close'));
    openSidebarBtn?.addEventListener('click', () => togglePanel(sidebarContainer, openSidebarBtn, 'open'));

    closeTocBtn?.addEventListener('click', () => togglePanel(tocContainer, openTocBtn, 'close'));
    openTocBtn?.addEventListener('click', () => togglePanel(tocContainer, openTocBtn, 'open'));

    // Initialize Mermaid
    const isDark = document.documentElement.classList.contains('dark');
    mermaid.initialize({
      startOnLoad: true,
      theme: isDark ? 'dark' : 'base',
      securityLevel: 'loose',
      fontFamily: 'LXGW WenKai',
      themeVariables: {
        primaryColor: '#5B6CF6',
        primaryTextColor: isDark ? '#fff' : '#1a1a1a',
        primaryBorderColor: '#5B6CF6',
        lineColor: '#5B6CF6',
        secondaryColor: '#3DAA6A',
        tertiaryColor: '#f3f4f6',
        mainBkg: isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.02)',
        nodeBorder: '#5B6CF6',
        clusterBkg: 'rgba(91,108,246,0.05)',
        clusterBorder: 'rgba(91,108,246,0.2)',
        edgeLabelBackground: isDark ? '#1a1a1a' : '#fff',
      }
    });

    const mermaidDivs = document.querySelectorAll('.mermaid');
    mermaidDivs.forEach(div => {
      const container = document.createElement('div');
      container.className = 'mermaid-glass-canvas';
      div.parentNode?.insertBefore(container, div);
      container.appendChild(div);

      // Add a decorative badge
      const badge = document.createElement('div');
      badge.className = 'mermaid-badge';
      badge.innerHTML = 'SYSTEM ARCHITECTURE';
      container.prepend(badge);
    });

    // Copy buttons
    const codeBlocks = document.querySelectorAll('pre');
    codeBlocks.forEach((block) => {
      const button = document.createElement('button');
      button.className = 'absolute top-4 right-4 p-2.5 glass-darker rounded-xl opacity-0 group-hover:opacity-100 transition-all hover:scale-110 active:scale-90';
      button.innerHTML = '<svg class="w-4 h-4 text-brand-blue" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';

      block.classList.add('group', 'relative');
      block.appendChild(button);

      button.addEventListener('click', async () => {
        const code = block.querySelector('code')?.innerText || '';
        await navigator.clipboard.writeText(code);
        button.innerHTML = '<svg class="w-4 h-4 text-brand-green" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
        setTimeout(() => {
          button.innerHTML = '<svg class="w-4 h-4 text-brand-blue" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';
        }, 2000);
      });
    });
  </script>

  <style is:global>
    @reference "../../styles/global.css";

    .custom-scrollbar::-webkit-scrollbar {
      width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: rgba(91, 108, 246, 0.1);
      border-radius: 9999px;
    }

    /* Premium Mermaid Styling */
    .mermaid-glass-canvas {
      @apply glass my-12 p-8 md:p-12 rounded-[3rem] border-2 border-brand-blue/10 relative overflow-hidden;
      background: radial-gradient(circle at top left, rgba(91,108,246,0.05), transparent);
    }

    .mermaid-badge {
      @apply absolute top-6 left-8 text-[10px] font-black tracking-[0.2em] text-brand-blue/40 uppercase;
    }

    .mermaid svg {
      max-width: 100% !important;
      height: auto !important;
      margin: 0 auto;
      filter: drop-shadow(0 10px 30px rgba(0,0,0,0.05));
    }

    /* Override Mermaid internal styles for that glass look */
    .mermaid .node rect,
    .mermaid .node polygon,
    .mermaid .node circle,
    .mermaid .node ellipse,
    .mermaid .node path {
      fill: rgba(255, 255, 255, 0.6) !important;
      stroke: #5B6CF6 !important;
      stroke-width: 1.5px !important;
      rx: 12 !important;
      ry: 12 !important;
    }

    .dark .mermaid .node rect,
    .dark .mermaid .node polygon,
    .dark .mermaid .node circle,
    .dark .mermaid .node ellipse,
    .dark .mermaid .node path {
      fill: rgba(30, 41, 59, 0.6) !important;
    }

    .mermaid .edgePath path {
      stroke: #5B6CF6 !important;
      stroke-width: 2px !important;
    }

    .mermaid .marker {
      fill: #5B6CF6 !important;
      stroke: none !important;
    }

    .mermaid .marker {
      fill: #5B6CF6 !important;
      stroke: none !important;
    }

    .mermaid .label {
      font-weight: 800 !important;
      color: #5B6CF6 !important;
    }

    .mermaid .cluster rect {
      fill: rgba(91, 108, 246, 0.03) !important;
      stroke: rgba(91, 108, 246, 0.2) !important;
      stroke-dasharray: 5, 5;
      rx: 20;
    }
  </style>
</BaseLayout>
