---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { ChevronRight, ExternalLink, Github, BookOpen } from 'lucide-astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs', ({ data }) => data.public !== false);
  return docs.map(doc => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content, headings } = await render(doc);

const title = doc.data.title ?? doc.id.split('/').pop() ?? doc.id;
const description = doc.data.description ?? `${title} — Tortoise 技术文档`;
const githubUrl = `${import.meta.env.PUBLIC_GITHUB_REPO ?? 'https://github.com/wuyxp/kotlin-stop-shortTV'}/blob/main/docs/${doc.id}.md`;
---

<BaseLayout title={title} description={description}>
  <!-- Background Light Glow -->
  <div class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none opacity-40">
     <div class="absolute top-1/4 right-0 w-[500px] h-[500px] bg-brand-blue/10 blur-[150px] rounded-full"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 py-12 md:py-20 flex flex-col lg:flex-row gap-16 relative">
    <!-- Left Sidebar -->
    <aside class="hidden lg:block w-72 shrink-0 sticky top-32 h-[calc(100vh-12rem)] overflow-y-auto pr-6 custom-scrollbar scroll-smooth">
      <Sidebar activeSlug={doc.id} />
    </aside>

    <!-- Main Content -->
    <article class="flex-1 min-w-0">
      <!-- Premium Breadcrumbs -->
      <nav class="flex items-center gap-3 text-[11px] font-black uppercase tracking-[0.15em] text-gray-400 mb-12">
        <a href="/" class="hover:text-brand-blue transition-colors">HOME</a>
        <ChevronRight size={14} class="text-gray-300" />
        <a href="/docs/readme" class="hover:text-brand-blue transition-colors">DOCS</a>
        <ChevronRight size={14} class="text-gray-300" />
        <span class="text-brand-green truncate">{doc.id}</span>
      </nav>

      <!-- Glass Content Wrap -->
      <div class="glass p-8 md:p-16 rounded-[3rem] shadow-2xl relative">
        <!-- Floating Badge -->
        <div class="absolute -top-6 left-12 glass-darker px-6 py-3 rounded-2xl flex items-center gap-3 text-sm font-black text-brand-blue shadow-lg border-2 border-brand-blue/10">
           <BookOpen size={18} />
           <span>INTERNAL DECISION LOG</span>
        </div>

        <div class="prose-tortoise">
          <Content />
        </div>
      </div>

      <!-- Enhanced Footer Metadata -->
      <footer class="mt-20 pt-12 border-t border-black/5 dark:border-white/5 space-y-8">
        <div class="flex flex-col sm:flex-row justify-between items-center gap-6">
           <div class="flex items-center gap-3 px-4 py-2 glass rounded-2xl text-xs font-bold text-gray-400">
             <span>SOURCE</span>
             <code class="bg-black/5 dark:bg-white/5 px-2 py-1 rounded text-[10px]">{doc.id}.md</code>
           </div>
           <a href={githubUrl} target="_blank" rel="noopener" class="flex items-center gap-2 glass-darker px-6 py-3 rounded-2xl text-sm font-black text-brand-blue hover:scale-105 transition-transform">
             <Github size={18} /> EDIT ON GITHUB <ExternalLink size={16} />
           </a>
        </div>

        <!-- Next/Prev Placeholder logic could go here -->
      </footer>
    </article>

    <!-- Right TOC -->
    <aside class="hidden xl:block w-64 shrink-0 sticky top-32 h-fit max-h-[calc(100vh-12rem)] overflow-y-auto">
      <div class="glass p-8 rounded-[2.5rem] border-2 border-black/5 dark:border-white/5">
        <TableOfContents headings={headings} />
      </div>
    </aside>
  </div>

  <!-- Mermaid & Script Injection -->
  <script>
    import mermaid from 'mermaid';

    // Initialize Mermaid
    const isDark = document.documentElement.classList.contains('dark');
    mermaid.initialize({
      startOnLoad: true,
      theme: isDark ? 'dark' : 'default',
      securityLevel: 'loose',
      fontFamily: 'LXGW WenKai',
      themeVariables: {
        primaryColor: '#5B6CF6',
        primaryTextColor: '#fff',
        lineColor: '#5B6CF6',
        secondaryColor: '#3DAA6A',
      }
    });

    // Wrap Mermaid diagrams in dashboards
    const mermaidDivs = document.querySelectorAll('.mermaid');
    mermaidDivs.forEach(div => {
      const container = document.createElement('div');
      container.className = 'mermaid-container';
      div.parentNode?.insertBefore(container, div);
      container.appendChild(div);
    });

    // Code block copy buttons
    const codeBlocks = document.querySelectorAll('pre');
    codeBlocks.forEach((block) => {
      const button = document.createElement('button');
      button.className = 'absolute top-4 right-4 p-2.5 glass-darker rounded-xl opacity-0 group-hover:opacity-100 transition-all hover:scale-110 active:scale-90';
      button.innerHTML = '<svg class="w-4 h-4 text-brand-blue" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';

      block.classList.add('group', 'relative');
      block.appendChild(button);

      button.addEventListener('click', async () => {
        const code = block.querySelector('code')?.innerText || '';
        await navigator.clipboard.writeText(code);

        button.innerHTML = '<svg class="w-4 h-4 text-brand-green" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
        setTimeout(() => {
          button.innerHTML = '<svg class="w-4 h-4 text-brand-blue" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';
        }, 2000);
      });
    });
  </script>

  <style is:global>
    .custom-scrollbar::-webkit-scrollbar {
      width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: rgba(91, 108, 246, 0.1);
      border-radius: 9999px;
    }

    /* Ensure Mermaid diagrams are responsive inside container */
    .mermaid svg {
      max-width: 100%;
      height: auto;
      margin-left: auto;
      margin-right: auto;
    }
  </style>
</BaseLayout>
