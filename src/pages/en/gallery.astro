---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GalleryCategory from '../../components/GalleryCategory.astro';
import { drawables } from '../../data/drawables';
import { ChevronRight, ChevronLeft, ChevronRight as ChevronRightIcon, Image as ImageIcon, X } from 'lucide-astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const categories = ['Creatures', 'Environment', 'Items', 'Story'] as const;
const title = `Gallery — Tortoise Exquisite Assets`;
const description = t('gallery.description');

const groupedAssets = categories.map(category => ({
  name: category,
  assets: drawables.filter(d => d.category === category)
}));
---

<BaseLayout title={title} description={description}>
  <!-- Background Light Glow -->
  <div class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none opacity-40">
     <div class="absolute top-1/4 right-0 w-[500px] h-[500px] bg-brand-blue/10 blur-[150px] rounded-full"></div>
     <div class="absolute bottom-1/4 left-0 w-[500px] h-[500px] bg-brand-green/10 blur-[150px] rounded-full"></div>
  </div>

  <main class="max-w-[1600px] mx-auto px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-3 text-[11px] font-black uppercase tracking-[0.15em] text-gray-400 mb-12">
      <a href={translatePath('/')} class="hover:text-brand-blue transition-colors">{t('gallery.breadcrumb.home')}</a>
      <ChevronRight size={14} class="text-gray-300" />
      <span class="text-brand-blue">{t('gallery.breadcrumb.gallery')}</span>
    </nav>

    <!-- Header Section -->
    <header class="mb-20 text-center">
      <div class="inline-flex items-center gap-3 glass px-6 py-2 rounded-2xl text-brand-blue text-sm font-black mb-8">
        <ImageIcon size={18} />
        <span>{t('gallery.badge')}</span>
      </div>
      <h1 class="text-5xl md:text-7xl font-black text-gray-900 dark:text-white mb-6 tracking-tight">
        {t('gallery.title1')} <span class="text-brand-blue">{t('gallery.title2')}</span>
      </h1>
      <p class="text-xl text-gray-500 max-w-2xl mx-auto font-medium">
        {t('gallery.description')}
      </p>
    </header>

    <!-- Gallery Categories -->
    {groupedAssets.map(group => (
      <GalleryCategory
        title={t(`gallery.category.${group.name.toLowerCase()}` as any)}
        assets={group.assets}
      />
    ))}
  </main>

  <!-- Lightbox Modal (Dialog) -->
  <dialog id="lightbox-dialog" class="m-auto bg-transparent backdrop:bg-black/95 backdrop:backdrop-blur-2xl p-0 border-0 overflow-visible max-w-[95vw] max-h-[95vh]">
    <div class="relative flex flex-col items-center justify-center p-4 md:p-12 w-full h-full group">

      <!-- Close Button -->
      <button id="close-lightbox" class="fixed top-8 right-8 p-4 glass rounded-2xl text-white/50 hover:text-white hover:scale-110 active:scale-90 transition-all z-[10001]">
        <X size={32} />
      </button>

      <!-- Navigation Buttons -->
      <button id="prev-btn" class="fixed left-4 md:left-8 p-4 glass rounded-full text-white/50 hover:text-white hover:scale-110 active:scale-90 transition-all z-[10001] top-1/2 -translate-y-1/2">
        <ChevronLeft size={48} />
      </button>
      <button id="next-btn" class="fixed right-4 md:right-8 p-4 glass rounded-full text-white/50 hover:text-white hover:scale-110 active:scale-90 transition-all z-[10001] top-1/2 -translate-y-1/2">
        <ChevronRightIcon size={48} />
      </button>

      <div class="flex flex-col items-center max-w-5xl w-full">
        <!-- Image Container -->
        <div class="glass p-3 md:p-6 rounded-[3rem] border-2 border-white/10 shadow-[0_0_100px_rgba(0,0,0,0.5)] mb-8 transition-transform duration-500 hover:scale-[1.02]">
          <img id="lightbox-img" src="" alt="" class="max-h-[65vh] w-auto rounded-[2rem] object-contain block opacity-0 transition-opacity duration-300" />
        </div>

        <!-- Info Area -->
        <div id="lightbox-info" class="text-center opacity-0 transition-opacity duration-300">
          <h2 id="lightbox-title" class="text-2xl md:text-5xl font-black text-white mb-4 tracking-tight"></h2>
          <p id="lightbox-description" class="text-sm md:text-xl text-gray-400 max-w-2xl mx-auto font-medium"></p>
        </div>
      </div>
    </div>
  </dialog>
</BaseLayout>

<script>
  const dialog = document.getElementById('lightbox-dialog') as HTMLDialogElement;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxTitle = document.getElementById('lightbox-title');
  const lightboxDescription = document.getElementById('lightbox-description');
  const lightboxInfo = document.getElementById('lightbox-info');
  const closeBtn = document.getElementById('close-lightbox');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const cards = document.querySelectorAll('.gallery-card');

  let currentIndex = 0;
  let allAssets: any[] = [];

  const initAssets = () => {
    const latestCards = document.querySelectorAll('.gallery-card');
    allAssets = Array.from(latestCards).map(card => {
      const htmlCard = card as HTMLElement;
      return {
        id: htmlCard.dataset.id,
        title: htmlCard.dataset.title,
        description: htmlCard.dataset.description,
        image: htmlCard.dataset.image
      };
    });
  };

  const updateLightbox = (index: number, immediate = false) => {
    if (!lightboxImg || !lightboxTitle || !lightboxDescription || !lightboxInfo) return;

    const asset = allAssets[index];
    if (!asset) return;

    currentIndex = index;

    if (!immediate) {
      lightboxImg.style.opacity = '0';
      lightboxInfo.style.opacity = '0';
    }

    const swap = () => {
      lightboxImg.src = asset.image || '';
      lightboxTitle.textContent = asset.title || '';
      lightboxDescription.textContent = asset.description || '';
      lightboxImg.style.opacity = '1';
      lightboxInfo.style.opacity = '1';
    };

    if (immediate) {
      swap();
    } else {
      setTimeout(swap, 300);
    }
  };

  const openLightbox = (index: number) => {
    if (!dialog) return;
    if (allAssets.length === 0) initAssets();

    updateLightbox(index, true);
    dialog.showModal();
    document.body.style.overflow = 'hidden';
  };

  const closeLightbox = () => {
    if (!dialog) return;
    dialog.close();
    document.body.style.overflow = '';
  };

  const nextImage = () => {
    const nextIdx = (currentIndex + 1) % allAssets.length;
    updateLightbox(nextIdx);
  };

  const prevImage = () => {
    const prevIdx = (currentIndex - 1 + allAssets.length) % allAssets.length;
    updateLightbox(prevIdx);
  };

  cards.forEach((card, index) => {
    card.addEventListener('click', (e) => {
      e.preventDefault();
      openLightbox(index);
    });
  });

  closeBtn?.addEventListener('click', closeLightbox);
  prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); prevImage(); });
  nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); nextImage(); });

  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (!dialog?.open) return;

    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') nextImage();
    if (e.key === 'ArrowLeft') prevImage();
  });

  dialog?.addEventListener('cancel', () => {
    document.body.style.overflow = '';
  });
</script>

<style is:global>
  @reference "../../styles/global.css";

  dialog#lightbox-dialog {
    display: none;
  }

  dialog#lightbox-dialog[open] {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100vw;
    height: 100vh;
  }

  dialog#lightbox-dialog .glass {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
  }

  dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.95);
    backdrop-filter: blur(12px);
  }
</style>
