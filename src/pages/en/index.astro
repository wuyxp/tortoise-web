---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DownloadCard from '../../components/DownloadCard.astro';
import { ShieldCheck, Zap, Smartphone, ArrowRight, QrCode, Sparkles } from 'lucide-astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const playStoreUrl = import.meta.env.PUBLIC_PLAY_STORE_URL ?? '#';
const domesticStoreUrl = import.meta.env.PUBLIC_DOMESTIC_STORE_URL ?? '#';
const feedbackEmail = import.meta.env.PUBLIC_FEEDBACK_EMAIL ?? 'support@serpilo.com';
const siteName = import.meta.env.PUBLIC_SITE_NAME ?? 'Tortoise';

const showPlayStore = playStoreUrl !== '#';
const showDomesticStore = domesticStoreUrl !== '#';

// APK Distribution
const apkDownloadUrl = import.meta.env.PUBLIC_APK_DOWNLOAD_URL ?? '#';
const apkDownloadUrlCn = import.meta.env.PUBLIC_APK_DOWNLOAD_URL_CN ?? '#';
const apkVersion = import.meta.env.PUBLIC_APK_VERSION ?? 'v0.0.0-pending';
const apkSha256Fp = import.meta.env.PUBLIC_APK_SHA256_FINGERPRINT ?? 'pending';
const apkSizeMb = import.meta.env.PUBLIC_APK_SIZE_MB ?? '80';
---

<BaseLayout>
  <!-- 1. Hero Section -->
  <section class="relative pt-24 pb-32 md:pt-40 md:pb-56 overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[120%] h-full -z-10 opacity-40">
       <div class="absolute top-0 left-1/4 w-96 h-96 bg-brand-green/20 blur-[120px] rounded-full"></div>
       <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-brand-blue/20 blur-[120px] rounded-full"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 items-center gap-16">
      <div class="space-y-10 text-center md:text-left">
        <div class="inline-flex items-center gap-2 px-5 py-2 glass rounded-full text-sm font-black text-brand-blue animate-fade-in">
           <Sparkles size={16} /> <span>{t('hero.badge')}</span>
        </div>
        <h1 class="text-5xl md:text-8xl font-black tracking-tight leading-[1.1]">
           {t('hero.title1')}<br />
           <span class="text-gradient">{t('hero.title2')}</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-500 dark:text-gray-400 max-w-xl leading-relaxed font-medium">
          {t('hero.description')}
        </p>
        <div class="flex flex-col sm:flex-row gap-5">
          <a href="#download" class="px-10 py-5 bg-brand-green text-white rounded-[2rem] font-black text-lg shadow-[0_20px_40px_-15px_rgba(61,170,106,0.3)] hover:scale-105 active:scale-95 transition-all">
            {t('hero.cta.start')}
          </a>
          <a href={translatePath('/gallery')} class="px-10 py-5 glass rounded-[2rem] font-black text-lg hover:bg-white/60 dark:hover:bg-gray-800/60 flex items-center justify-center gap-3 transition-all group">
            {t('hero.cta.gallery')} <ArrowRight size={20} class="group-hover:translate-x-2 transition-transform" />
          </a>
        </div>
      </div>

      <div class="relative group">
        <!-- Premium Multi-layered Illustration Container -->
        <div class="relative z-10 animate-float flex justify-center items-center">
           <!-- Outer Glass Frame (Rotating) -->
           <div class="absolute inset-0 bg-white/5 dark:bg-black/5 rounded-[4rem] blur-2xl -z-10 group-hover:scale-110 transition-transform duration-1000"></div>

           <!-- Glass Content Frame -->
           <div class="relative p-2 glass-frame overflow-hidden organic-radius shadow-2xl rotate-[1.5deg] group-hover:rotate-0 transition-transform duration-700">
              <div class="absolute inset-0 bg-gradient-to-br from-brand-blue/10 via-transparent to-brand-green/10 opacity-50"></div>
              <img src="/v2/characters/character_mori_solo.webp" alt="Hero" class="w-full max-w-lg mx-auto drop-shadow-2xl fade-mask mix-blend-normal dark:mix-blend-lighten" />

              <!-- Inner Glossy Overlay -->
              <div class="absolute inset-0 pointer-events-none border-[1px] border-white/20 organic-radius shadow-[inset_0_0_80px_rgba(255,255,255,0.1)]"></div>
           </div>

           <!-- Floating Accent Elements -->
           <div class="absolute -top-12 -left-12 w-24 h-24 glass rounded-3xl organic-radius flex items-center justify-center animate-float-delayed shadow-xl">
              <Sparkles size={32} class="text-brand-blue" />
           </div>
           <div class="absolute -bottom-8 -right-8 w-32 h-32 glass-darker rounded-[2.5rem] organic-radius p-6 animate-float shadow-2xl">
              <img src="/favicon.svg" class="w-full h-full opacity-40 grayscale group-hover:grayscale-0 transition-all" alt="" />
           </div>
        </div>

        <!-- Background Ambient Glow -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[140%] h-[140%] bg-brand-blue/5 blur-[100px] rounded-full -z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>
      </div>
    </div>
  </section>

  <!-- 2. Bento Why Tortoise -->
  <section class="py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-4 md:grid-rows-2 gap-6 min-h-[700px]">
        <!-- 1. Six Stages Block (Large) -->
        <div class="md:col-span-2 md:row-span-2 glass p-12 rounded-[3.5rem] relative overflow-hidden group hover:-translate-y-2 transition-all duration-500">
           <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-brand-green/10 rounded-full blur-[80px] group-hover:bg-brand-green/20 transition-colors"></div>

           <div class="flex items-start justify-between mb-10">
              <Zap size={64} class="text-brand-green" />
              <!-- Visual Indicator: Stage Progress Ring -->
              <div class="relative w-24 h-24 flex items-center justify-center">
                 <svg class="w-full h-full -rotate-90">
                    <circle cx="48" cy="48" r="40" stroke="currentColor" stroke-width="8" fill="transparent" class="text-black/5 dark:text-white/5" />
                    <circle cx="48" cy="48" r="40" stroke="currentColor" stroke-width="8" fill="transparent" stroke-dasharray="251.2" stroke-dashoffset="75.36" class="text-brand-green opacity-60 group-hover:opacity-100 transition-all duration-1000" />
                 </svg>
                 <span class="absolute text-sm font-black text-brand-green">STAGE 4</span>
              </div>
           </div>

           <h3 class="text-4xl font-black mb-6">{t('bento.stages.title')}</h3>
           <p class="text-xl text-gray-500 dark:text-gray-400 leading-relaxed font-medium">
             {t('bento.stages.description')}
           </p>

           <!-- Decorative floating dots -->
           <div class="mt-12 flex gap-3">
              {[1, 2, 3, 4, 5, 6].map((i) => (
                <div class={`w-10 h-2 rounded-full ${i <= 4 ? 'bg-brand-green shadow-[0_0_15px_rgba(61,170,106,0.5)]' : 'bg-gray-200 dark:bg-gray-800'}`}></div>
              ))}
           </div>

           <img src="/images/illu_tortoise_wave.webp" class="absolute right-12 bottom-12 w-32 h-32 object-contain opacity-20 group-hover:rotate-12 group-hover:scale-110 transition-transform duration-700" alt="" />
        </div>

        <!-- 2. Privacy Block (Wide) -->
        <div class="md:col-span-2 glass-darker p-10 rounded-[3.5rem] flex flex-col justify-between border-brand-blue/20 group hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
           <div class="absolute inset-0 bg-gradient-to-r from-brand-blue/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
           <div class="flex justify-between items-start relative z-10">
              <ShieldCheck size={48} class="text-brand-blue" />
              <div class="px-4 py-1.5 bg-brand-blue/10 rounded-full text-[10px] font-black text-brand-blue">SECURITY: HIGH</div>
           </div>

           <!-- Privacy Visual: Local DB Concept -->
           <div class="my-6 relative h-24 flex items-center gap-4 px-4">
              <div class="w-16 h-16 glass rounded-2xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                 <div class="w-8 h-8 border-4 border-brand-blue/30 rounded-full border-t-brand-blue animate-spin"></div>
              </div>
              <div class="flex-1 space-y-2 opacity-40 group-hover:opacity-100 transition-opacity">
                 <div class="h-2 w-3/4 bg-brand-blue/20 rounded-full"></div>
                 <div class="h-2 w-1/2 bg-brand-blue/20 rounded-full"></div>
              </div>
              <div class="absolute -right-4 top-0 text-[60px] font-black text-brand-blue/5 pointer-events-none uppercase">LOCAL ONLY</div>
           </div>

           <div class="relative z-10">
              <h3 class="text-3xl font-black mb-4">{t('bento.privacy.title')}</h3>
              <p class="text-gray-500 dark:text-gray-400 font-medium leading-relaxed">
                {t('bento.privacy.description')}
              </p>
           </div>
        </div>

        <!-- 3. Brands Block (Square) -->
        <div class="md:col-span-1 glass p-8 rounded-[3.5rem] flex flex-col items-center justify-center text-center gap-6 group hover:-translate-y-2 transition-all duration-500">
           <div class="grid grid-cols-2 gap-2 opacity-30 group-hover:opacity-100 transition-opacity duration-700">
              <div class="w-8 h-8 glass rounded-lg flex items-center justify-center"><Smartphone size={16} /></div>
              <div class="w-8 h-8 glass rounded-lg flex items-center justify-center"><div class="w-4 h-4 bg-gray-400 rounded-sm"></div></div>
              <div class="w-8 h-8 glass rounded-lg flex items-center justify-center"><div class="w-4 h-4 bg-gray-400 rounded-full"></div></div>
              <div class="w-8 h-8 glass rounded-lg flex items-center justify-center"><Smartphone size={16} class="rotate-45" /></div>
           </div>
           <div>
              <h4 class="font-black text-xl mb-1">{t('bento.brands.title')}</h4>
              <p class="text-[10px] font-bold text-gray-400 tracking-widest uppercase">{t('bento.brands.subtitle')}</p>
           </div>
        </div>

        <!-- 4. Logic Block (Square, Dark) -->
        <div class="md:col-span-1 bg-gray-900 dark:bg-white p-8 rounded-[3.5rem] flex flex-col items-center justify-center text-center gap-4 group hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
           <div class="absolute inset-0 opacity-10 group-hover:opacity-20 transition-opacity">
              <div class="grid grid-cols-4 gap-1 p-2 h-full">
                 {Array.from({length: 16}).map(() => <div class="bg-brand-blue rounded-sm"></div>)}
              </div>
           </div>
           <a href={translatePath('/docs/public/01-gentle-guidance-philosophy')} class="text-white dark:text-black font-black flex flex-col items-center gap-3 group-hover:scale-110 transition-transform text-center relative z-10">
              <Sparkles size={32} class="text-brand-blue animate-pulse" />
              <span class="text-lg">{t('bento.logic.title')}</span>
           </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Crystal Journal Section -->
  <section class="py-32 relative">
    <div class="max-w-7xl mx-auto px-6">
      <div class="glass rounded-[4rem] p-12 md:p-24 flex flex-col md:flex-row items-center gap-20 relative overflow-hidden">
        <div class="absolute inset-0 noise opacity-5 pointer-events-none"></div>

        <div class="flex-1 space-y-10 relative z-10 text-center md:text-left">
           <div class="inline-block px-5 py-2 glass rounded-2xl organic-radius text-sm font-black text-orange-600">{t('journal.badge')}</div>
           <h3 class="text-4xl md:text-6xl font-black leading-tight">{t('journal.title1')}<br /><span class="text-gradient">{t('journal.title2')}</span></h3>
           <p class="text-xl text-gray-500 dark:text-gray-400 leading-relaxed font-medium">
             {t('journal.description')}
           </p>
           <div class="pt-6">
             <a href={translatePath('/docs/public/04-explorer-gameplay-for-kids')} class="inline-flex items-center gap-3 font-black text-brand-blue group">
                {t('journal.cta')} <div class="w-12 h-12 glass rounded-full flex items-center justify-center group-hover:translate-x-4 transition-all"><ArrowRight size={20} /></div>
             </a>
           </div>
        </div>

        <div class="flex-1 relative group">
           <div class="relative">
              <div class="glass-frame p-6 organic-radius shadow-inner">
                <img src="/v2/scenes/captain_mora_listening.webp" alt="Captain Mora listening" class="w-full max-w-md mx-auto rotate-[-2deg] group-hover:rotate-0 transition-transform duration-700 fade-mask" />
              </div>
              <div class="absolute -top-10 -right-10 glass-darker w-48 h-48 organic-radius p-8 animate-float shadow-2xl">
                 <img src="/images/illu_tortoise_peek.webp" class="w-full h-full object-contain" alt="Peek" />
              </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Download Crystal Panel -->
  <section id="download" class="py-32">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-4xl md:text-6xl font-black mb-16 tracking-tight">{t('download.title1')}<br /><span class="text-gradient">{t('download.title2')}</span></h2>

      {(!showPlayStore && !showDomesticStore) ? (
        <DownloadCard
          apkUrl={apkDownloadUrl}
          apkUrlCn={apkDownloadUrlCn}
          version={apkVersion}
          sha256Fp={apkSha256Fp}
          sizeMb={apkSizeMb}
          feedbackEmail={feedbackEmail}
          lang={lang}
        />
      ) : (
        <div class="flex flex-col sm:flex-row justify-center gap-8">
          {showPlayStore && (
            <a href={playStoreUrl} target="_blank" rel="noopener" class="flex items-center gap-4 glass-darker px-12 py-6 rounded-[2rem] font-black text-xl hover:scale-105 transition-all">
               <img src="/favicon.svg" class="w-8 h-8" alt="" />
               Google Play
            </a>
          )}
          {showDomesticStore && (
            <a href={domesticStoreUrl} target="_blank" rel="noopener" class="flex items-center gap-4 bg-brand-blue text-white px-12 py-6 rounded-[2rem] font-black text-xl shadow-2xl shadow-brand-blue/30 hover:scale-105 transition-all">
               <Smartphone size={24} />
               本地应用商店
            </a>
          )}
        </div>
      )}
    </div>
  </section>

</BaseLayout>
