---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';
import { Sparkles, BookOpen, Anchor, Map, Ship } from 'lucide-astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const title = 'Island Story — Heritage & Companionship';
const description = 'Explore the seven-year voyage of Captain Mora and Mori.';

const years = [
  {
    id: 'y1',
    title: 'Y1 "The Voyage Begins"',
    subtitle: 'You are not starting alone',
    image: '/v2/chapters/chapter_y1_prologue.webp',
    color: 'tide-gold',
    quote: '"Light is passed on from one person to another."',
    content: 'The day they set out, Captain Mora walked into the sea. It was his last time in the water, and Mori\'s first departure. Thirty stories, thirty stars, memories awakened.'
  },
  {
    id: 'y2',
    title: 'Y2 "Distant Tides"',
    subtitle: 'Getting lost is finding the unnamed',
    image: '/v2/chapters/chapter_y2_prologue.webp',
    color: 'deep-cyan',
    quote: '"Go as far as you can go over there."',
    content: 'Mori saw a young Captain Mora in the mist. He walked a road without a name. In those uncharted waters, he understood the true meaning of heritage.'
  },
  {
    id: 'y3',
    title: 'Y3 "The Echo"',
    subtitle: 'You dare to move forward knowing they are there',
    image: '/v2/chapters/chapter_y3_prologue.webp',
    color: 'tide-gold',
    quote: '"Starting today on your own. You know it yourself."',
    content: 'The Spineback Tree grew its first leaf. Mori began choosing his own paths, knowing the island and the Captain were always behind him.'
  },
  {
    id: 'y4',
    title: 'Y4 "The Sunken Bell"',
    subtitle: 'The deeper you go, the more light waits',
    image: '/v2/chapters/chapter_y4_prologue.webp',
    color: 'deep-cyan',
    quote: '"You have gone to a place deeper than I have."',
    content: 'Diving until the light vanished. Mori dove deeper than the Captain. In the eternal silence of the abyss, he found the lamp and made the ancient bell resonate through the ocean.'
  },
  {
    id: 'y5',
    title: 'Y5 "The Ancient Kin"',
    subtitle: 'Old things gain weight in new hands',
    image: '/v2/chapters/chapter_y5_prologue.webp',
    color: 'tide-gold',
    quote: '"You are part of a very long story."',
    content: 'Silhouettes of seven ancestors appeared, leaving a fragmented star map. A forgotten history reconnected in Mori\'s hands; he was no longer just himself.'
  },
  {
    id: 'y6',
    title: 'Y6 "Guardian"',
    subtitle: 'Knowing how to watch over another',
    image: '/v2/scenes/mori_at_island.webp',
    color: 'deep-cyan',
    quote: '"He was holding a piece of driftwood. Mori recognized it. The one pushed back in Y3."',
    content: 'Cinta drifted ashore. Mori watched over him with a familiar gaze — the same one Captain Mora once gave him. The companion became the guide.'
  },
  {
    id: 'y7',
    title: 'Y7 "The Dawn"',
    subtitle: 'Going for a walk, the lighthouse is yours',
    image: '/v2/scenes/mori_lighthouse.webp',
    color: 'tide-gold',
    quote: '"The lighthouse is yours."',
    content: 'The Time Mist cleared completely. Captain Mora left a letter, and Mori took over the responsibility of the watcher. Dawn has arrived, and light will forever illuminate the sea.'
  }
];
---

<BaseLayout title={title} description={description}>
  <main class="pt-32 pb-24">
    <div class="max-w-5xl mx-auto px-6">
      <!-- Header -->
      <div class="text-center mb-24 space-y-6">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 glass rounded-full text-xs font-black text-brand-blue uppercase tracking-widest animate-fade-in">
           <Sparkles size={14} /> <span>The Seven Years Epic</span>
        </div>
        <h1 class="text-5xl md:text-7xl font-black dark:text-slate-300 tracking-tight">
          Seven Years, One <span class="text-gradient">Light</span>
        </h1>
        <p class="text-xl text-gray-500 dark:text-slate-400 max-w-2xl mx-auto font-medium leading-relaxed">
          A story of companionship, growth, and heritage. Guided by Captain Mora, Mori sets off from Sandbell Shoal, through the Time Mist, until the entire ocean is lit.
        </p>
      </div>

      <!-- Timeline -->
      <div class="relative space-y-32">
        <!-- Center Line (Desktop) -->
        <div class="absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-brand-blue/20 via-brand-green/20 to-transparent -translate-x-1/2 hidden md:block"></div>

        {years.map((year, index) => (
          <div class={`relative flex flex-col md:flex-row items-center gap-12 ${index % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
            <!-- Image Card -->
            <div class="flex-1 w-full group">
              <div class="glass-frame p-2 organic-radius overflow-hidden shadow-2xl transition-all duration-700 group-hover:scale-[1.02] group-hover:-rotate-1">
                <div class="relative aspect-[4/3] overflow-hidden organic-radius">
                  <img src={year.image} alt={year.title} class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-8">
                     <p class="text-white font-bold italic text-lg leading-relaxed">{year.quote}</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Indicator Dot -->
            <div class="absolute left-1/2 -translate-x-1/2 w-12 h-12 glass rounded-full hidden md:flex items-center justify-center z-10 shadow-xl border-4 border-white dark:border-gray-900">
               <div class={`w-4 h-4 rounded-full bg-${year.color} animate-pulse`}></div>
            </div>

            <!-- Content Card -->
            <div class="flex-1 space-y-6 text-center md:text-left">
              <div class="space-y-2">
                <span class={`text-sm font-black text-${year.color} uppercase tracking-widest`}>{year.title}</span>
                <h2 class="text-3xl md:text-4xl font-black dark:text-slate-300">{year.subtitle}</h2>
              </div>
              <p class="text-lg text-gray-500 dark:text-slate-400 font-medium leading-relaxed">
                {year.content}
              </p>

              <div class="pt-4 flex flex-wrap justify-center md:justify-start gap-4">
                <div class="px-4 py-2 glass rounded-xl flex items-center gap-2 text-sm font-bold text-gray-600 dark:text-gray-300">
                   {index === 0 ? <Anchor size={16} /> : index === 3 ? <Ship size={16} /> : <Map size={16} />}
                   <span>{index === 0 ? 'Departure' : index === 3 ? 'Deep Dive' : 'Exploration'}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Final CTA -->
      <div class="mt-48 text-center glass rounded-[3rem] p-12 md:p-24 relative overflow-hidden group">
        <div class="absolute -top-24 -right-24 w-64 h-64 bg-brand-green/10 rounded-full blur-3xl group-hover:scale-150 transition-transform duration-1000"></div>
        <div class="relative z-10 space-y-10">
           <h2 class="text-4xl md:text-6xl font-black dark:text-slate-300 leading-tight">
             Light Up Your <br /><span class="text-gradient">Starshell Path</span>
           </h2>
           <p class="text-xl text-gray-500 dark:text-slate-400 max-w-xl mx-auto font-medium">
             Your seven-year epic has only just begun. Mori is waiting, and so is Captain Mora.
           </p>
           <div class="flex flex-col sm:flex-row justify-center gap-6">
              <a href={translatePath('/') + '#download'} class="px-10 py-5 bg-brand-blue text-white rounded-3xl font-black text-lg shadow-2xl shadow-brand-blue/20 hover:scale-105 active:scale-95 transition-all">
                Bring Mori Home
              </a>
              <a href={translatePath('/gallery')} class="px-10 py-5 glass rounded-3xl font-black text-lg hover:bg-white/60 dark:hover:bg-gray-800/60 transition-all">
                View Gallery
              </a>
           </div>
        </div>

        <!-- Decorative Background Image -->
        <img src="/v2/scenes/mori_lighthouse.webp" class="absolute inset-0 w-full h-full object-cover opacity-5 group-hover:scale-110 transition-transform duration-1000 pointer-events-none" alt="" />
      </div>
    </div>
  </main>
</BaseLayout>
