---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryCategory from '../components/GalleryCategory.astro';
import { drawables } from '../data/drawables';
import { ChevronRight, ChevronLeft, ChevronRight as ChevronRightIcon, Image as ImageIcon, X, Maximize2 } from 'lucide-astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const categories = ['Creatures', 'Environment', 'Items', 'Story'] as const;
const title = `Gallery — Tortoise Exquisite Assets`;
const description = t('gallery.description');

const groupedAssets = categories.map(category => ({
  name: category,
  assets: drawables.filter(d => d.category === category)
}));
---

<BaseLayout title={title} description={description}>
  <!-- Background Light Glow -->
  <div class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none opacity-40">
     <div class="absolute top-1/4 right-0 w-[500px] h-[500px] bg-brand-blue/10 blur-[150px] rounded-full"></div>
     <div class="absolute bottom-1/4 left-0 w-[500px] h-[500px] bg-brand-green/10 blur-[150px] rounded-full"></div>
  </div>

  <main class="max-w-[1600px] mx-auto px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-3 text-[11px] font-black uppercase tracking-[0.15em] text-gray-400 mb-12">
      <a href={translatePath('/')} class="hover:text-brand-blue transition-colors">{t('gallery.breadcrumb.home')}</a>
      <ChevronRight size={14} class="text-gray-300" />
      <span class="text-brand-blue">{t('gallery.breadcrumb.gallery')}</span>
    </nav>

    <!-- Header Section -->
    <header class="mb-20 text-center">
      <div class="inline-flex items-center gap-3 glass px-6 py-2 rounded-2xl text-brand-blue text-sm font-black mb-8">
        <ImageIcon size={18} />
        <span>{t('gallery.badge')}</span>
      </div>
      <h1 class="text-5xl md:text-7xl font-black text-gray-900 dark:text-white mb-6 tracking-tight">
        {t('gallery.title1')} <span class="text-brand-blue">{t('gallery.title2')}</span>
      </h1>
      <p class="text-xl text-gray-500 max-w-2xl mx-auto font-medium">
        {t('gallery.description')}
      </p>
    </header>

    <!-- Gallery Categories -->
    {groupedAssets.map(group => (
      <GalleryCategory
        title={t(`gallery.category.${group.name.toLowerCase()}` as any)}
        assets={group.assets}
      />
    ))}
  </main>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-50 flex items-center justify-center bg-black/95 backdrop-blur-2xl opacity-0 pointer-events-none transition-all duration-500">
    <button id="close-lightbox" class="absolute top-8 right-8 p-4 glass rounded-2xl text-white/50 hover:text-white hover:scale-110 active:scale-90 transition-all z-[60]">
      <X size={32} />
    </button>

    <!-- Navigation Buttons -->
    <button id="prev-btn" class="absolute left-4 md:left-8 p-4 glass rounded-full text-white/50 hover:text-white hover:scale-110 active:scale-90 transition-all z-[60]">
      <ChevronLeft size={48} />
    </button>
    <button id="next-btn" class="absolute right-4 md:right-8 p-4 glass rounded-full text-white/50 hover:text-white hover:scale-110 active:scale-90 transition-all z-[60]">
      <ChevronRightIcon size={48} />
    </button>

    <div class="max-w-6xl w-full p-6 flex flex-col items-center relative">
      <div class="glass p-4 rounded-[3rem] border-2 border-white/10 relative group mb-8 shadow-2xl overflow-hidden">
        <img id="lightbox-img" src="" alt="" class="max-h-[75vh] w-auto rounded-[2rem] object-contain transition-all duration-500 block" />
        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
           <div class="p-4 glass rounded-full text-white shadow-2xl">
             <Maximize2 size={48} />
           </div>
        </div>
      </div>

      <div id="lightbox-info" class="text-center animate-fade-in">
        <h2 id="lightbox-title" class="text-3xl md:text-5xl font-black text-white mb-4 tracking-tight"></h2>
        <p id="lightbox-description" class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto font-medium"></p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxTitle = document.getElementById('lightbox-title');
  const lightboxDescription = document.getElementById('lightbox-description');
  const closeBtn = document.getElementById('close-lightbox');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const cards = document.querySelectorAll('.gallery-card');

  let currentIndex = 0;
  let allAssets: any[] = [];

  const initAssets = () => {
    allAssets = Array.from(document.querySelectorAll('.gallery-card')).map(card => {
      const htmlCard = card as HTMLElement;
      return {
        id: htmlCard.dataset.id,
        title: htmlCard.dataset.title,
        description: htmlCard.dataset.description,
        image: htmlCard.dataset.image
      };
    });
  };

  const updateLightbox = (index: number, immediate = false) => {
    if (!lightboxImg || !lightboxTitle || !lightboxDescription) return;

    const asset = allAssets[index];
    if (!asset) return;

    currentIndex = index;

    if (immediate) {
      lightboxImg.src = asset.image || '';
      lightboxTitle.textContent = asset.title || '';
      lightboxDescription.textContent = asset.description || '';
      lightboxImg.style.opacity = '1';
      lightboxImg.style.transform = 'scale(1)';
    } else {
      lightboxImg.style.opacity = '0';
      lightboxImg.style.transform = 'scale(0.95)';

      setTimeout(() => {
        lightboxImg.src = asset.image || '';
        lightboxTitle.textContent = asset.title || '';
        lightboxDescription.textContent = asset.description || '';
        lightboxImg.style.opacity = '1';
        lightboxImg.style.transform = 'scale(1)';
      }, 200);
    }
  };

  const openLightbox = (index: number) => {
    if (!lightbox) return;
    if (allAssets.length === 0) initAssets();

    updateLightbox(index, true);
    lightbox.classList.remove('opacity-0', 'pointer-events-none');
    document.body.style.overflow = 'hidden';
  };

  const closeLightbox = () => {
    if (!lightbox) return;
    lightbox.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
  };

  const nextImage = () => {
    const nextIdx = (currentIndex + 1) % allAssets.length;
    updateLightbox(nextIdx);
  };

  const prevImage = () => {
    const prevIdx = (currentIndex - 1 + allAssets.length) % allAssets.length;
    updateLightbox(prevIdx);
  };

  cards.forEach((card, index) => {
    card.addEventListener('click', () => openLightbox(index));
  });

  closeBtn?.addEventListener('click', closeLightbox);
  prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); prevImage(); });
  nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); nextImage(); });

  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (lightbox?.classList.contains('pointer-events-none')) return;

    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') nextImage();
    if (e.key === 'ArrowLeft') prevImage();
  });
</script>

<style is:global>
  @reference "../styles/global.css";

  /* Premium Glass Lightbox Effect */
  #lightbox .glass {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in {
    animation: fade-in 0.5s ease-out forwards;
  }
</style>
