---
// 主页骨架 (MEETING-2026-05-11-05-static-website-v1, Phase A)
// PM 标准 7 块: Hero + Captain Tort + Why Tortoise 三块 + 下载按钮 + 隐私承诺 + 反馈邮箱 + /docs 入口
// Gemini 后续接力精修视觉 (海岛风 / Captain Tort 资产 / 动画)
import BaseLayout from '../layouts/BaseLayout.astro';

const playStoreUrl = import.meta.env.PUBLIC_PLAY_STORE_URL ?? '#';
const domesticStoreUrl = import.meta.env.PUBLIC_DOMESTIC_STORE_URL ?? '#';
const githubRepo = import.meta.env.PUBLIC_GITHUB_REPO ?? 'https://github.com/wuyxp/kotlin-stop-shortTV';
const feedbackEmail = import.meta.env.PUBLIC_FEEDBACK_EMAIL ?? 'tortoise@example.com';
const siteName = import.meta.env.PUBLIC_SITE_NAME ?? 'Tortoise';

const showPlayStore = playStoreUrl !== '#';
const showDomesticStore = domesticStoreUrl !== '#';
---

<BaseLayout>
  <!-- 1. Hero -->
  <section class="text-center py-16">
    <div class="text-7xl mb-6">🐢</div>
    <h1 class="text-4xl md:text-5xl font-bold text-headline-blue mb-4">
      陪伴孩子建立健康的屏幕使用习惯
    </h1>
    <p class="text-lg text-gray-600 max-w-2xl mx-auto">
      {siteName} 通过游戏化激励和六阶段渐进式提醒,<br />
      引导 6-14 岁儿童学会自主管理短视频时间.
    </p>
    <p class="text-sm text-brand-green mt-6 italic">
      "温柔引导, 逐步收紧" — 不强制关闭目标 App, 只在 100% 限额后启动锁定
    </p>
  </section>

  <!-- 2. Why Tortoise 三块 -->
  <section class="py-16">
    <h2 class="text-3xl font-bold text-center text-headline-blue mb-12">
      为什么选择 {siteName}
    </h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white rounded-2xl p-6 shadow-sm">
        <div class="text-3xl mb-3">🤝</div>
        <h3 class="text-xl font-semibold mb-2 text-brand-green">不强制锁屏</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          六阶段渐进提醒 (温和→友好→严肃→100%阻断), 引导式而非对抗式,
          让孩子学会自主管理而非被惩罚.
        </p>
      </div>
      <div class="bg-white rounded-2xl p-6 shadow-sm">
        <div class="text-3xl mb-3">🔒</div>
        <h3 class="text-xl font-semibold mb-2 text-brand-green">离线优先</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          所有数据本地存储, 零云端追踪, 零账号注册.
          匿名 install_id 仅用于崩溃统计, 符合儿童隐私守底.
        </p>
      </div>
      <div class="bg-white rounded-2xl p-6 shadow-sm">
        <div class="text-3xl mb-3">📱</div>
        <h3 class="text-xl font-semibold mb-2 text-brand-green">8 品牌 ROM 兼容</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          华为 / 小米 / OPPO / vivo / 三星 / 一加 / 魅族 / 联想 全适配,
          能力探测 + 引导表驱动, 无厂商分支 hack.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. Captain Tort 区 (Gemini 后续接入海龟形象资产) -->
  <section class="bg-coach-card rounded-3xl p-12 text-center my-16">
    <div class="text-6xl mb-4">🐢</div>
    <h3 class="text-2xl font-bold mb-3">Captain Tort 守护中</h3>
    <p class="text-gray-600 max-w-xl mx-auto">
      探险队长会带孩子在龟岛上完成派遣任务, 把"省下的屏幕时间"变成探险币,
      解锁岛屿建筑、收集图鉴、写下日记 — 让节制变成乐趣.
    </p>
    <p class="text-xs text-gray-400 mt-4">
      [Gemini 接力: Captain Tort 海龟形象插画引入]
    </p>
  </section>

  <!-- 4. 下载按钮 -->
  <section class="py-16 text-center">
    <h2 class="text-3xl font-bold text-headline-blue mb-8">立即下载</h2>
    {(!showPlayStore && !showDomesticStore) && (
      <p class="text-gray-500 italic">应用上架准备中, 敬请期待</p>
    )}
    <div class="flex justify-center gap-4 flex-wrap">
      {showPlayStore && (
        <a
          href={playStoreUrl}
          target="_blank"
          rel="noopener"
          class="inline-block bg-brand-green text-white px-8 py-4 rounded-full font-semibold hover:opacity-90 transition"
        >
          Google Play 下载
        </a>
      )}
      {showDomesticStore && (
        <a
          href={domesticStoreUrl}
          target="_blank"
          rel="noopener"
          class="inline-block bg-brand-blue text-white px-8 py-4 rounded-full font-semibold hover:opacity-90 transition"
        >
          国内应用商店
        </a>
      )}
    </div>
  </section>

  <!-- 5. 隐私承诺 -->
  <section class="bg-lavender rounded-3xl p-10 my-16">
    <h3 class="text-2xl font-bold text-center text-headline-blue mb-6">隐私守底</h3>
    <ul class="max-w-2xl mx-auto space-y-3 text-gray-700">
      <li>✓ 零账号注册, 零云端账户</li>
      <li>✓ 所有数据存本地数据库, 卸载即清除</li>
      <li>✓ 不收集姓名 / 手机 / 位置 / 通讯录</li>
      <li>✓ 仅匿名 install_id 用于崩溃统计 (可一键清空)</li>
      <li>✓ COPPA / Family Policy 合规设计</li>
    </ul>
  </section>

  <!-- 6. /docs 入口 -->
  <section class="py-12 text-center">
    <h3 class="text-xl font-semibold mb-3">技术透明</h3>
    <p class="text-gray-600 mb-6">
      {siteName} 的全部架构、决策、测试矩阵公开可查
    </p>
    <a
      href="/docs/readme"
      class="inline-block border border-brand-blue text-brand-blue px-6 py-3 rounded-full hover:bg-brand-blue hover:text-white transition"
    >
      查阅技术文档 →
    </a>
  </section>

  <!-- 7. 反馈 -->
  <section class="py-12 text-center">
    <h3 class="text-xl font-semibold mb-3">反馈与联系</h3>
    <p class="text-gray-600">
      问题、建议、合作:
      <a href={`mailto:${feedbackEmail}`} class="text-brand-blue hover:underline">
        {feedbackEmail}
      </a>
    </p>
    <p class="text-gray-600 mt-2">
      源码:
      <a href={githubRepo} target="_blank" rel="noopener" class="text-brand-blue hover:underline">
        GitHub
      </a>
    </p>
  </section>
</BaseLayout>
