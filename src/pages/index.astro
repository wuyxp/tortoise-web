---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ShieldCheck, Zap, Smartphone, ArrowRight, QrCode, Sparkles } from 'lucide-astro';

const playStoreUrl = import.meta.env.PUBLIC_PLAY_STORE_URL ?? '#';
const domesticStoreUrl = import.meta.env.PUBLIC_DOMESTIC_STORE_URL ?? '#';
const githubRepo = import.meta.env.PUBLIC_GITHUB_REPO ?? 'https://github.com/wuyxp/kotlin-stop-shortTV';
const feedbackEmail = import.meta.env.PUBLIC_FEEDBACK_EMAIL ?? 'tortoise@example.com';
const siteName = import.meta.env.PUBLIC_SITE_NAME ?? 'Tortoise';

const showPlayStore = playStoreUrl !== '#';
const showDomesticStore = domesticStoreUrl !== '#';
---

<BaseLayout>
  <!-- 1. Hero Section -->
  <section class="relative pt-24 pb-32 md:pt-40 md:pb-56 overflow-hidden">
    <!-- Background Elements -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[120%] h-full -z-10 opacity-40">
       <div class="absolute top-0 left-1/4 w-96 h-96 bg-brand-green/20 blur-[120px] rounded-full"></div>
       <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-brand-blue/20 blur-[120px] rounded-full"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 items-center gap-16">
      <div class="space-y-10 text-center md:text-left">
        <div class="inline-flex items-center gap-2 px-5 py-2 glass rounded-full text-sm font-black text-brand-blue animate-fade-in">
           <Sparkles size={16} /> <span>THE FUTURE OF TIME MANAGEMENT</span>
        </div>
        <h1 class="text-5xl md:text-8xl font-black tracking-tight leading-[1.1]">
           让屏幕时间<br />
           <span class="text-gradient">回归自由</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-500 dark:text-gray-400 max-w-xl leading-relaxed font-medium">
          {siteName} 是专为 6-14 岁儿童设计的探险伙伴。通过透明的技术逻辑与游戏化叙事，引导孩子学会自主掌控。
        </p>
        <div class="flex flex-col sm:flex-row gap-5">
          <a href="#download" class="px-10 py-5 bg-brand-green text-white rounded-[2rem] font-black text-lg shadow-[0_20px_40px_-15px_rgba(61,170,106,0.3)] hover:scale-105 active:scale-95 transition-all">
            开始探险
          </a>
          <a href="/docs/readme" class="px-10 py-5 glass rounded-[2rem] font-black text-lg hover:bg-white/60 dark:hover:bg-gray-800/60 flex items-center justify-center gap-3 transition-all group">
            技术白皮书 <ArrowRight size={20} class="group-hover:translate-x-2 transition-transform" />
          </a>
        </div>
      </div>

      <div class="relative group">
        <!-- Floating Illustration -->
        <div class="relative z-10 animate-float">
           <img src="/images/illu_tortoise_sunrise.webp" alt="Hero" class="w-full max-w-lg mx-auto drop-shadow-[0_40px_60px_rgba(0,0,0,0.15)] dark:drop-shadow-[0_40px_60px_rgba(91,108,246,0.3)]" />
        </div>
        <!-- Decorative Organic Shape -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] glass organic-radius -z-10 opacity-20 scale-90 group-hover:scale-100 transition-transform duration-1000"></div>
      </div>
    </div>
  </section>

  <!-- 2. Bento Why Tortoise -->
  <section class="py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-4 md:grid-rows-2 gap-6 h-[700px]">
        <!-- Main Logic Card -->
        <div class="md:col-span-2 md:row-span-2 glass p-12 rounded-[3.5rem] relative overflow-hidden group">
           <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-brand-green/10 rounded-full blur-[80px] group-hover:bg-brand-green/20 transition-colors"></div>
           <Zap size={64} class="text-brand-green mb-10" />
           <h3 class="text-4xl font-black mb-6">六阶段<br />温和提醒</h3>
           <p class="text-xl text-gray-500 dark:text-gray-400 leading-relaxed font-medium">
             从低优先级通知到高亮遮罩，我们不搞突然袭击。给予孩子足够的“缓冲区”，让他们在最后锁定前有时间完成手中的游戏。
           </p>
           <img src="/images/illu_tortoise_wave.webp" class="absolute right-12 bottom-12 w-32 h-32 object-contain opacity-20 group-hover:rotate-12 transition-transform duration-700" alt="" />
        </div>

        <!-- Privacy Card -->
        <div class="md:col-span-2 glass-darker p-10 rounded-[3.5rem] flex flex-col justify-between border-brand-blue/20">
           <div class="flex justify-between items-start">
              <ShieldCheck size={48} class="text-brand-blue" />
              <div class="px-4 py-1.5 bg-brand-blue/10 rounded-full text-[10px] font-black text-brand-blue">SECURITY: HIGH</div>
           </div>
           <div>
              <h3 class="text-3xl font-black mb-4">隐私即是正义</h3>
              <p class="text-gray-500 dark:text-gray-400 font-medium leading-relaxed">
                零云端同步。所有计时、配置、日记均存储在设备本地 Room 数据库中。
              </p>
           </div>
        </div>

        <!-- Compatibility Card -->
        <div class="md:col-span-1 glass p-8 rounded-[3.5rem] flex flex-col items-center justify-center text-center gap-4">
           <Smartphone size={40} class="text-headline-blue" />
           <h4 class="font-black text-xl">8 品牌<br />完美适配</h4>
        </div>

        <!-- Transparency Card -->
        <div class="md:col-span-1 bg-gray-900 dark:bg-white p-8 rounded-[3.5rem] flex flex-col items-center justify-center text-center gap-4 group">
           <a href="/docs/readme" class="text-white dark:text-black font-black flex flex-col items-center gap-2 group-hover:scale-110 transition-transform">
              <Sparkles size={32} />
              <span>逻辑全透明</span>
           </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Crystal Journal Section -->
  <section class="py-32 relative">
    <div class="max-w-7xl mx-auto px-6">
      <div class="glass rounded-[4rem] p-12 md:p-24 flex flex-col md:row items-center gap-20 relative overflow-hidden">
        <!-- Decoration Sand Texture -->
        <div class="absolute inset-0 noise opacity-5 pointer-events-none"></div>

        <div class="flex-1 space-y-10 relative z-10 text-center md:text-left">
           <div class="inline-block px-5 py-2 glass rounded-2xl organic-radius text-sm font-black text-orange-600">ADVENTURE LOG</div>
           <h3 class="text-4xl md:text-6xl font-black leading-tight">将每一秒节省的时间<br /><span class="text-gradient">铸造成勋章</span></h3>
           <p class="text-xl text-gray-500 dark:text-gray-400 leading-relaxed font-medium">
             Captain Tort 不仅是监管者，更是探险队长。孩子节省下的屏幕时间会变成“探险币”，用于解锁龟岛上的神秘建筑。
           </p>
           <div class="pt-6">
             <a href="/docs/04-narrative/e14-island-lore-bible" class="inline-flex items-center gap-3 font-black text-brand-blue group">
                探索岛屿传说圣经 <div class="w-12 h-12 glass rounded-full flex items-center justify-center group-hover:translate-x-4 transition-all"><ArrowRight size={20} /></div>
             </a>
           </div>
        </div>

        <div class="flex-1 relative group">
           <!-- Letter with Glass Overlay -->
           <div class="relative">
              <img src="/images/captain_tort_letter.webp" alt="Letter" class="w-full max-w-md mx-auto rotate-[-2deg] drop-shadow-2xl group-hover:rotate-0 transition-transform duration-700" />
              <div class="absolute -top-10 -right-10 glass-darker w-48 h-48 organic-radius p-8 animate-float">
                 <img src="/images/illu_tortoise_peek.webp" class="w-full h-full object-contain" alt="Peek" />
              </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Download Crystal Panel -->
  <section id="download" class="py-32">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-4xl md:text-6xl font-black mb-16 tracking-tight">立即加入<br /><span class="text-gradient">Alpha 测试</span></h2>

      {(!showPlayStore && !showDomesticStore) ? (
        <div class="glass p-16 rounded-[4rem] border-2 border-brand-blue/10 relative group">
          <div class="absolute inset-0 bg-brand-blue/5 blur-3xl rounded-[4rem] -z-10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <p class="text-2xl font-black text-brand-blue mb-6 tracking-tight">APP 上架准备中</p>
          <p class="text-lg text-gray-500 dark:text-gray-400 mb-12 font-medium">正在进行最后的设备兼容性调试。请扫码加入 Alpha 开发者群：</p>
          <div class="flex flex-col items-center gap-8">
            <div class="w-56 h-56 glass p-6 rounded-[2.5rem] relative">
              <div class="absolute inset-0 bg-white dark:bg-gray-800 rounded-[2.5rem] -z-10"></div>
              <QrCode size={176} strokeWidth={1.5} class="text-gray-300 dark:text-gray-600" />
            </div>
            <a href={`mailto:${feedbackEmail}`} class="text-brand-green font-black text-xl hover:scale-110 transition-transform flex items-center gap-3">
               订阅发布动态 <ArrowRight />
            </a>
          </div>
        </div>
      ) : (
        <div class="flex flex-col sm:flex-row justify-center gap-8">
          {showPlayStore && (
            <a href={playStoreUrl} target="_blank" rel="noopener" class="flex items-center gap-4 glass-darker px-12 py-6 rounded-[2rem] font-black text-xl hover:scale-105 transition-all">
               <img src="/favicon.svg" class="w-8 h-8" alt="" />
               Google Play
            </a>
          )}
          {showDomesticStore && (
            <a href={domesticStoreUrl} target="_blank" rel="noopener" class="flex items-center gap-4 bg-brand-blue text-white px-12 py-6 rounded-[2rem] font-black text-xl shadow-2xl shadow-brand-blue/30 hover:scale-105 transition-all">
               <Smartphone size={24} />
               本地应用商店
            </a>
          )}
        </div>
      )}
    </div>
  </section>

</BaseLayout>
